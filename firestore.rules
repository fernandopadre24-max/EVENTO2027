/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model, ensuring that each user can only access data they own.
 *
 * Data Structure:
 * All data is stored in top-level collections: /clients/{clientId}, /artists/{artistId}, /events/{eventId}, /finances/{financeId}, and /purchases/{purchaseId}.
 * Each document in these collections has a 'userId' field indicating the owner.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed to prevent unauthorized data discovery.
 * - All write operations (create, update, delete) are restricted to the owner of the document, verified via the 'userId' field.
 * - Read operations (get, list) are also restricted to the owner, ensuring data privacy.
 *
 * Denormalization for Authorization:
 * The 'userId' field is crucial for authorization. It is denormalized (copied) into each document to allow simple and efficient ownership checks without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own client documents.
     * @path /clients/{clientId}
     * @allow (create) User A with auth.uid "user_abc" can create a client document where client.userId == "user_abc".
     * @deny (create) User A with auth.uid "user_abc" cannot create a client document where client.userId != "user_abc".
     * @allow (get) User A with auth.uid "user_abc" can read a client document where client.userId == "user_abc".
     * @deny (get) User A with auth.uid "user_abc" cannot read a client document where client.userId != "user_abc".
     * @allow (update) User A with auth.uid "user_abc" can update a client document where client.userId == "user_abc".
     * @deny (update) User A with auth.uid "user_abc" cannot update a client document where client.userId != "user_abc".
     * @allow (delete) User A with auth.uid "user_abc" can delete a client document where client.userId == "user_abc".
     * @deny (delete) User A with auth.uid "user_abc" cannot delete a client document where client.userId != "user_abc".
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(clientId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows users to read and write their own artist documents.
     * @path /artists/{artistId}
     * @allow (create) User A with auth.uid "user_abc" can create an artist document where artist.userId == "user_abc".
     * @deny (create) User A with auth.uid "user_abc" cannot create an artist document where artist.userId != "user_abc".
     * @allow (get) User A with auth.uid "user_abc" can read an artist document where artist.userId == "user_abc".
     * @deny (get) User A with auth.uid "user_abc" cannot read an artist document where artist.userId != "user_abc".
     * @allow (update) User A with auth.uid "user_abc" can update an artist document where artist.userId == "user_abc".
     * @deny (update) User A with auth.uid "user_abc" cannot update an artist document where artist.userId != "user_abc".
     * @allow (delete) User A with auth.uid "user_abc" can delete an artist document where artist.userId == "user_abc".
     * @deny (delete) User A with auth.uid "user_abc" cannot delete an artist document where artist.userId != "user_abc".
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(artistId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows users to read and write their own event documents.
     * @path /events/{eventId}
     * @allow (create) User A with auth.uid "user_abc" can create an event document where event.userId == "user_abc".
     * @deny (create) User A with auth.uid "user_abc" cannot create an event document where event.userId != "user_abc".
     * @allow (get) User A with auth.uid "user_abc" can read an event document where event.userId == "user_abc".
     * @deny (get) User A with auth.uid "user_abc" cannot read an event document where event.userId != "user_abc".
     * @allow (update) User A with auth.uid "user_abc" can update an event document where event.userId == "user_abc".
     * @deny (update) User A with auth.uid "user_abc" cannot update an event document where event.userId != "user_abc".
     * @allow (delete) User A with auth.uid "user_abc" can delete an event document where event.userId == "user_abc".
     * @deny (delete) User A with auth.uid "user_abc" cannot delete an event document where event.userId != "user_abc".
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(eventId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows users to read and write their own finance documents.
     * @path /finances/{financeId}
     * @allow (create) User A with auth.uid "user_abc" can create a finance document where finance.userId == "user_abc".
     * @deny (create) User A with auth.uid "user_abc" cannot create a finance document where finance.userId != "user_abc".
     * @allow (get) User A with auth.uid "user_abc" can read a finance document where finance.userId == "user_abc".
     * @deny (get) User A with auth.uid "user_abc" cannot read a finance document where finance.userId != "user_abc".
     * @allow (update) User A with auth.uid "user_abc" can update a finance document where finance.userId == "user_abc".
     * @deny (update) User A with auth.uid "user_abc" cannot update a finance document where finance.userId != "user_abc".
     * @allow (delete) User A with auth.uid "user_abc" can delete a finance document where finance.userId == "user_abc".
     * @deny (delete) User A with auth.uid "user_abc" cannot delete a finance document where finance.userId != "user_abc".
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(financeId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows users to read and write their own purchase documents.
     * @path /purchases/{purchaseId}
     * @allow (create) User A with auth.uid "user_abc" can create a purchase document where purchase.userId == "user_abc".
     * @deny (create) User A with auth.uid "user_abc" cannot create a purchase document where purchase.userId != "user_abc".
     * @allow (get) User A with auth.uid "user_abc" can read a purchase document where purchase.userId == "user_abc".
     * @deny (get) User A with auth.uid "user_abc" cannot read a purchase document where purchase.userId != "user_abc".
     * @allow (update) User A with auth.uid "user_abc" can update a purchase document where purchase.userId == "user_abc".
     * @deny (update) User A with auth.uid "user_abc" cannot update a purchase document where purchase.userId != "user_abc".
     * @allow (delete) User A with auth.uid "user_abc" can delete a purchase document where purchase.userId == "user_abc".
     * @deny (delete) User A with auth.uid "user_abc" cannot delete a purchase document where purchase.userId != "user_abc".
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(purchaseId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the document
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Helper function to determine if the user is the existing owner of the document
  function isExistingOwner(userId) {
    return request.auth.uid == userId && resource != null;
  }
}