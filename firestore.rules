/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, and only that user can create, read, update, or delete the document.
 *
 * Data Structure:
 * - /clients/{clientId}: Stores client information, owned by a user.
 * - /artists/{artistId}: Stores artist information, owned by a user.
 * - /events/{eventId}: Stores event information, owned by a user.
 * - /finances/{financeId}: Stores financial information, owned by a user.
 * - /purchases/{purchaseId}: Stores purchase information, owned by a user.
 *
 * Key Security Decisions:
 * - User-owned data: All top-level collections are secured based on user ownership, enforced via the `userId` field in each document.
 * - No listing of all documents: Listing of all documents in any collection is only allowed for the owner. There are no public lists.
 * - Data consistency: On create, rules validate that the `userId` field matches the authenticated user's ID. On update, the `userId` field is immutable.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the `/clients` collection. Only the owner (identified by `userId`) can create, read, update, or delete client documents.
     * @path /clients/{clientId}
     * @allow (create) User A creates a client document with client.userId == userA.uid.
     * @allow (get, list) User A reads a client document where client.userId == userA.uid.
     * @allow (update) User A updates a client document where client.userId == userA.uid.
     * @allow (delete) User A deletes a client document where client.userId == userA.uid.
     * @deny (create) User A attempts to create a client document with client.userId == userB.uid.
     * @deny (get, list) User B attempts to read a client document where client.userId == userA.uid.
     * @deny (update) User B attempts to update a client document where client.userId == userA.uid.
     * @deny (delete) User B attempts to delete a client document where client.userId == userA.uid.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (resource.data.userId == request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `/artists` collection. Only the owner (identified by `userId`) can create, read, update, or delete artist documents.
     * @path /artists/{artistId}
     * @allow (create) User A creates an artist document with artist.userId == userA.uid.
     * @allow (get, list) User A reads an artist document where artist.userId == userA.uid.
     * @allow (update) User A updates an artist document where artist.userId == userA.uid.
     * @allow (delete) User A deletes an artist document where artist.userId == userA.uid.
     * @deny (create) User A attempts to create an artist document with artist.userId == userB.uid.
     * @deny (get, list) User B attempts to read an artist document where artist.userId == userA.uid.
     * @deny (update) User B attempts to update an artist document where artist.userId == userA.uid.
     * @deny (delete) User B attempts to delete an artist document where artist.userId == userA.uid.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (resource.data.userId == request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `/events` collection. Only the owner (identified by `userId`) can create, read, update, or delete event documents.
     * @path /events/{eventId}
     * @allow (create) User A creates an event document with event.userId == userA.uid.
     * @allow (get, list) User A reads an event document where event.userId == userA.uid.
     * @allow (update) User A updates an event document where event.userId == userA.uid.
     * @allow (delete) User A deletes an event document where event.userId == userA.uid.
     * @deny (create) User A attempts to create an event document with event.userId == userB.uid.
     * @deny (get, list) User B attempts to read an event document where event.userId == userA.uid.
     * @deny (update) User B attempts to update an event document where event.userId == userA.uid.
     * @deny (delete) User B attempts to delete an event document where event.userId == userA.uid.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (resource.data.userId == request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `/finances` collection. Only the owner (identified by `userId`) can create, read, update, or delete finance documents.
     * @path /finances/{financeId}
     * @allow (create) User A creates a finance document with finance.userId == userA.uid.
     * @allow (get, list) User A reads a finance document where finance.userId == userA.uid.
     * @allow (update) User A updates a finance document where finance.userId == userA.uid.
     * @allow (delete) User A deletes a finance document where finance.userId == userA.uid.
     * @deny (create) User A attempts to create a finance document with finance.userId == userB.uid.
     * @deny (get, list) User B attempts to read a finance document where finance.userId == userA.uid.
     * @deny (update) User B attempts to update a finance document where finance.userId == userA.uid.
     * @deny (delete) User B attempts to delete a finance document where finance.userId == userA.uid.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (resource.data.userId == request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `/purchases` collection. Only the owner (identified by `userId`) can create, read, update, or delete purchase documents.
     * @path /purchases/{purchaseId}
     * @allow (create) User A creates a purchase document with purchase.userId == userA.uid.
     * @allow (get, list) User A reads a purchase document where purchase.userId == userA.uid.
     * @allow (update) User A updates a purchase document where purchase.userId == userA.uid.
     * @allow (delete) User A deletes a purchase document where purchase.userId == userA.uid.
     * @deny (create) User A attempts to create a purchase document with purchase.userId == userB.uid.
     * @deny (get, list) User B attempts to read a purchase document where purchase.userId == userA.uid.
     * @deny (update) User B attempts to update a purchase document where purchase.userId == userA.uid.
     * @deny (delete) User B attempts to delete a purchase document where purchase.userId == userA.uid.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (resource.data.userId == request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}