/**
 * @fileOverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, identified by the `userId` field. Only the owning user can create, read, update,
 * or delete these documents.
 *
 * Data Structure:
 * The Firestore database is organized into top-level collections:
 * - /clients/{clientId}
 * - /artists/{artistId}
 * - /events/{eventId}
 * - /finances/{financeId}
 * - /purchases/{purchaseId}
 * Each document within these collections contains a `userId` field indicating ownership.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed to prevent unauthorized data access.
 * - All write operations are protected by an `isOwner()` check, ensuring that only the owner can modify data.
 * - In the case of public read with owner-only write collections, the ownerId/authorId validation will be implemented.
 *
 * Denormalization for Authorization:
 * To avoid costly `get()` calls and improve rule performance, the `userId` is denormalized into each document.
 * This allows the rules to quickly verify ownership without additional database reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the /clients collection to ensure only the owner can manage client data.
     * @path /clients/{clientId}
     * @allow (create) - User A creates a new client document with client.userId == request.auth.uid.
     * @allow (get, update, delete) - User A can read, update, or delete a client document where client.userId == request.auth.uid.
     * @deny (create) - User A attempts to create a client document with client.userId != request.auth.uid.
     * @deny (get, update, delete) - User B attempts to read, update, or delete a client document where client.userId == request.auth.uid (User A's client).
     * @principle Enforces document ownership for all operations on the /clients collection.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /artists collection to ensure only the owner can manage artist data.
     * @path /artists/{artistId}
     * @allow (create) - User A creates a new artist document with artist.userId == request.auth.uid.
     * @allow (get, update, delete) - User A can read, update, or delete an artist document where artist.userId == request.auth.uid.
     * @deny (create) - User A attempts to create an artist document with artist.userId != request.auth.uid.
     * @deny (get, update, delete) - User B attempts to read, update, or delete an artist document where artist.userId == request.auth.uid (User A's artist).
     * @principle Enforces document ownership for all operations on the /artists collection.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /events collection to ensure only the owner can manage event data.
     * @path /events/{eventId}
     * @allow (create) - User A creates a new event document with event.userId == request.auth.uid.
     * @allow (get, update, delete) - User A can read, update, or delete an event document where event.userId == request.auth.uid.
     * @deny (create) - User A attempts to create an event document with event.userId != request.auth.uid.
     * @deny (get, update, delete) - User B attempts to read, update, or delete an event document where event.userId == request.auth.uid (User A's event).
     * @principle Enforces document ownership for all operations on the /events collection.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /finances collection to ensure only the owner can manage finance data.
     * @path /finances/{financeId}
     * @allow (create) - User A creates a new finance document with finance.userId == request.auth.uid.
     * @allow (get, update, delete) - User A can read, update, or delete a finance document where finance.userId == request.auth.uid.
     * @deny (create) - User A attempts to create a finance document with finance.userId != request.auth.uid.
     * @deny (get, update, delete) - User B attempts to read, update, or delete a finance document where finance.userId == request.auth.uid (User A's finance).
     * @principle Enforces document ownership for all operations on the /finances collection.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /purchases collection to ensure only the owner can manage purchase data.
     * @path /purchases/{purchaseId}
     * @allow (create) - User A creates a new purchase document with purchase.userId == request.auth.uid.
     * @allow (get, update, delete) - User A can read, update, or delete a purchase document where purchase.userId == request.auth.uid.
     * @deny (create) - User A attempts to create a purchase document with purchase.userId != request.auth.uid.
     * @deny (get, update, delete) - User B attempts to read, update, or delete a purchase document where purchase.userId == request.auth.uid (User A's purchase).
     * @principle Enforces document ownership for all operations on the /purchases collection.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}