/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, and only that user can create, read, update, or delete the document.
 *
 * Data Structure:
 * The Firestore database has the following top-level collections:
 * - /clients/{clientId}: Stores client information.
 * - /artists/{artistId}: Stores artist information.
 * - /events/{eventId}: Stores event information.
 * - /finances/{financeId}: Stores financial information.
 * - /purchases/{purchaseId}: Stores purchase information.
 * All documents in these collections must have a `userId` field that matches the authenticated user's UID.
 *
 * Key Security Decisions:
 * - User listing is disallowed for all collections to protect user privacy.
 * - The ruleset assumes that all collections contain private user data.
 * - Data validation is limited to authorization-critical fields (e.g., `userId`). The prototyping philosophy grants more flexibility on other fields.
 *
 * Denormalization for Authorization:
 * - Each document includes a `userId` field, enabling easy enforcement of user-ownership without requiring additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource and the resource exists.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /clients collection.
     * @path /clients/{clientId}
     * @allow (create) A user with UID 'user123' can create a new client document if request.resource.data.userId == 'user123'.
     * @allow (get) A user with UID 'user123' can get a client document with userId == 'user123'.
     * @allow (update) A user with UID 'user123' can update a client document with userId == 'user123' if the document exists.
     * @allow (delete) A user with UID 'user123' can delete a client document with userId == 'user123' if the document exists.
     * @deny (create) A user with UID 'user456' cannot create a new client document if request.resource.data.userId != 'user456'.
     * @deny (get) A user with UID 'user456' cannot get a client document with userId == 'user123'.
     * @deny (update) A user with UID 'user456' cannot update a client document with userId == 'user123'.
     * @deny (delete) A user with UID 'user456' cannot delete a client document with userId == 'user123'.
     * @principle Enforces document ownership for writes, restricts listing to owners, and validates relational integrity.
     */
    match /clients/{clientId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /artists collection.
     * @path /artists/{artistId}
     * @allow (create) A user with UID 'user123' can create a new artist document if request.resource.data.userId == 'user123'.
     * @allow (get) A user with UID 'user123' can get an artist document with userId == 'user123'.
     * @allow (update) A user with UID 'user123' can update an artist document with userId == 'user123' if the document exists.
     * @allow (delete) A user with UID 'user123' can delete an artist document with userId == 'user123' if the document exists.
     * @deny (create) A user with UID 'user456' cannot create a new artist document if request.resource.data.userId != 'user456'.
     * @deny (get) A user with UID 'user456' cannot get an artist document with userId == 'user123'.
     * @deny (update) A user with UID 'user456' cannot update an artist document with userId == 'user123'.
     * @deny (delete) A user with UID 'user456' cannot delete an artist document with userId == 'user123'.
     * @principle Enforces document ownership for writes, restricts listing to owners, and validates relational integrity.
     */
    match /artists/{artistId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /events collection.
     * @path /events/{eventId}
     * @allow (create) A user with UID 'user123' can create a new event document if request.resource.data.userId == 'user123'.
     * @allow (get) A user with UID 'user123' can get an event document with userId == 'user123'.
     * @allow (update) A user with UID 'user123' can update an event document with userId == 'user123' if the document exists.
     * @allow (delete) A user with UID 'user123' can delete an event document with userId == 'user123' if the document exists.
     * @deny (create) A user with UID 'user456' cannot create a new event document if request.resource.data.userId != 'user456'.
     * @deny (get) A user with UID 'user456' cannot get an event document with userId == 'user123'.
     * @deny (update) A user with UID 'user456' cannot update an event document with userId == 'user123'.
     * @deny (delete) A user with UID 'user456' cannot delete an event document with userId == 'user123'.
     * @principle Enforces document ownership for writes, restricts listing to owners, and validates relational integrity.
     */
    match /events/{eventId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /finances collection.
     * @path /finances/{financeId}
     * @allow (create) A user with UID 'user123' can create a new finance document if request.resource.data.userId == 'user123'.
     * @allow (get) A user with UID 'user123' can get a finance document with userId == 'user123'.
     * @allow (update) A user with UID 'user123' can update a finance document with userId == 'user123' if the document exists.
     * @allow (delete) A user with UID 'user123' can delete a finance document with userId == 'user123' if the document exists.
     * @deny (create) A user with UID 'user456' cannot create a new finance document if request.resource.data.userId != 'user456'.
     * @deny (get) A user with UID 'user456' cannot get a finance document with userId == 'user123'.
     * @deny (update) A user with UID 'user456' cannot update a finance document with userId == 'user123'.
     * @deny (delete) A user with UID 'user456' cannot delete a finance document with userId == 'user123'.
     * @principle Enforces document ownership for writes, restricts listing to owners, and validates relational integrity.
     */
    match /finances/{financeId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (create) A user with UID 'user123' can create a new purchase document if request.resource.data.userId == 'user123'.
     * @allow (get) A user with UID 'user123' can get a purchase document with userId == 'user123'.
     * @allow (update) A user with UID 'user123' can update a purchase document with userId == 'user123' if the document exists.
     * @allow (delete) A user with UID 'user123' can delete a purchase document with userId == 'user123' if the document exists.
     * @deny (create) A user with UID 'user456' cannot create a new purchase document if request.resource.data.userId != 'user456'.
     * @deny (get) A user with UID 'user456' cannot get a purchase document with userId == 'user123'.
     * @deny (update) A user with UID 'user456' cannot update a purchase document with userId == 'user123'.
     * @deny (delete) A user with UID 'user456' cannot delete a purchase document with userId == 'user123'.
     * @principle Enforces document ownership for writes, restricts listing to owners, and validates relational integrity.
     */
    match /purchases/{purchaseId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}