/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each data entity (Client, Artist, Event, Finance, Purchase)
 * is owned by a specific user, identified by the `userId` field.  Access is granted only to the owner of the data,
 * preventing unauthorized access or modification.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for each entity type: `/clients/{clientId}`, `/artists/{artistId}`,
 * `/events/{eventId}`, `/finances/{financeId}`, and `/purchases/{purchaseId}`.  Each document within these collections
 * contains a `userId` field indicating the owner.
 *
 * Key Security Decisions:
 * - User listing is disallowed for all collections to prevent information leakage.
 * - Write operations (create, update, delete) are strictly limited to the owner of the data.
 * - The ruleset prioritizes simplicity and security, omitting complex data validation in favor of rapid prototyping.
 *
 * Denormalization for Authorization:
 * The `userId` field is included in each document to allow for efficient ownership checks within the rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects against unauthorized access.
     * @path /
     * @allow (get) N/A
     * @deny (get) N/A
     * @principle Root path is protected.
     */
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }


    /**
     * @description Manages access to client information.
     * @path /clients/{clientId}
     * @allow (create) Authenticated user creates a client with their userId.
     * @allow (get) Authenticated user retrieves a client they own.
     * @allow (update) Authenticated user updates a client they own.
     * @allow (delete) Authenticated user deletes a client they own.
     * @deny (create) User attempts to create a client for another user.
     * @deny (update) User attempts to update a client they don't own.
     * @deny (delete) User attempts to delete a client they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId) && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to artist information.
     * @path /artists/{artistId}
     * @allow (create) Authenticated user creates an artist with their userId.
     * @allow (get) Authenticated user retrieves an artist they own.
     * @allow (update) Authenticated user updates an artist they own.
     * @allow (delete) Authenticated user deletes an artist they own.
     * @deny (create) User attempts to create an artist for another user.
     * @deny (update) User attempts to update an artist they don't own.
     * @deny (delete) User attempts to delete an artist they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId) && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to event information.
     * @path /events/{eventId}
     * @allow (create) Authenticated user creates an event with their userId.
     * @allow (get) Authenticated user retrieves an event they own.
     * @allow (update) Authenticated user updates an event they own.
     * @allow (delete) Authenticated user deletes an event they own.
     * @deny (create) User attempts to create an event for another user.
     * @deny (update) User attempts to update an event they don't own.
     * @deny (delete) User attempts to delete an event they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId) && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to financial information.
     * @path /finances/{financeId}
     * @allow (create) Authenticated user creates a finance record with their userId.
     * @allow (get) Authenticated user retrieves a finance record they own.
     * @allow (update) Authenticated user updates a finance record they own.
     * @allow (delete) Authenticated user deletes a finance record they own.
     * @deny (create) User attempts to create a finance record for another user.
     * @deny (update) User attempts to update a finance record they don't own.
     * @deny (delete) User attempts to delete a finance record they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId) && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to purchase information.
     * @path /purchases/{purchaseId}
     * @allow (create) Authenticated user creates a purchase with their userId.
     * @allow (get) Authenticated user retrieves a purchase they own.
     * @allow (update) Authenticated user updates a purchase they own.
     * @allow (delete) Authenticated user deletes a purchase they own.
     * @deny (create) User attempts to create a purchase for another user.
     * @deny (update) User attempts to update a purchase they don't own.
     * @deny (delete) User attempts to delete a purchase they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId) && isOwner(resource.data.userId);
    }
  }
}