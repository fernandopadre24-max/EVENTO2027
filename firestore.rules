/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, identified by the `userId` field.  Access is generally restricted to the owner.
 *
 * Data Structure:
 * - /clients/{clientId}: Stores information about clients, each owned by a user.
 * - /artists/{artistId}: Stores information about artists, each owned by a user.
 * - /events/{eventId}: Stores information about events, each owned by a user and associated with clients and artists.
 * - /finances/{financeId}: Stores financial records, each owned by a user and optionally associated with events and artists.
 * - /purchases/{purchaseId}: Stores purchase records, each owned by a user.
 *
 * Key Security Decisions:
 * - User Ownership: All data is strictly owned by a user and only accessible to that user.
 * - No Listing All Users: Listing all users in the database is disallowed.
 * - Data Validation: Data validation is minimized in this prototyping phase, focusing on authorization.
 * - Public Read Restriction: There are no public read collections.  All collections require authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the document.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     */
    function isExistingOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && resource != null;
    }

    /**
     * @description Rules for the /artists collection.
     * @path /artists/{artistId}
     * @allow (list) User with auth.uid: 'someUserId' can list their own artists if they are the owner.
     * @deny (list) User with auth.uid: 'anotherUserId' cannot list artists if they are not the owner.
     * @allow (create) User with auth.uid: 'someUserId' can create an artist with userId: 'someUserId'.
     * @deny (create) User with auth.uid: 'someUserId' cannot create an artist with userId: 'anotherUserId'.
     * @allow (get) User with auth.uid: 'someUserId' can get an artist with userId: 'someUserId'.
     * @deny (get) User with auth.uid: 'anotherUserId' cannot get an artist with userId: 'someUserId'.
     * @principle Enforces document ownership for all operations on artists.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /clients collection.
     * @path /clients/{clientId}
     * @allow (create) User with auth.uid: 'someUserId' can create a client with userId: 'someUserId'.
     * @deny (create) User with auth.uid: 'someUserId' cannot create a client with userId: 'anotherUserId'.
     * @allow (get) User with auth.uid: 'someUserId' can get a client with userId: 'someUserId'.
     * @deny (get) User with auth.uid: 'anotherUserId' cannot get a client with userId: 'someUserId'.
     * @principle Enforces document ownership for all operations on clients.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /events collection.
     * @path /events/{eventId}
     * @allow (create) User with auth.uid: 'someUserId' can create an event with userId: 'someUserId'.
     * @deny (create) User with auth.uid: 'someUserId' cannot create an event with userId: 'anotherUserId'.
     * @allow (get) User with auth.uid: 'someUserId' can get an event with userId: 'someUserId'.
     * @deny (get) User with auth.uid: 'anotherUserId' cannot get an event with userId: 'someUserId'.
     * @principle Enforces document ownership for all operations on events.
     */
    match /events/{eventId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /finances collection.
     * @path /finances/{financeId}
     * @allow (create) User with auth.uid: 'someUserId' can create a finance record with userId: 'someUserId'.
     * @deny (create) User with auth.uid: 'someUserId' cannot create a finance record with userId: 'anotherUserId'.
     * @allow (get) User with auth.uid: 'someUserId' can get a finance record with userId: 'someUserId'.
     * @deny (get) User with auth.uid: 'anotherUserId' cannot get a finance record with userId: 'someUserId'.
     * @principle Enforces document ownership for all operations on finances.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (create) User with auth.uid: 'someUserId' can create a purchase record with userId: 'someUserId'.
     * @deny (create) User with auth.uid: 'someUserId' cannot create a purchase record with userId: 'anotherUserId'.
     * @allow (get) User with auth.uid: 'someUserId' can get a purchase record with userId: 'someUserId'.
     * @deny (get) User with auth.uid: 'anotherUserId' cannot get a purchase record with userId: 'someUserId'.
     * @principle Enforces document ownership for all operations on purchases.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}