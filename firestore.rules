/**
 * @fileOverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document is owned by a specific user,
 * and only that user can read, create, update, or delete the document.
 *
 * Data Structure:
 * The Firestore database is structured with top-level collections for clients, artists, events, finances, and purchases.
 * Each document in these collections contains a `userId` field indicating the owner.
 *
 * Key Security Decisions:
 * - Users can only access their own data. Listing other users' data is disallowed.
 * - All writes require a valid, authenticated user.
 *
 * Denormalization for Authorization:
 * The `userId` field is present in all document types to enable simple and performant ownership checks. This avoids
 * the need for complex queries or additional reads to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /clients/{clientId} collection.
     * @path /databases/{database}/documents/clients/{clientId}
     * @allow (create) User with UID 'user_abc' can create a client if client.userId == 'user_abc'.
     * @allow (get, list) User with UID 'user_abc' can read a client if client.userId == 'user_abc'.
     * @allow (update, delete) User with UID 'user_abc' can update/delete a client if client.userId == 'user_abc'.
     * @deny (create) User with UID 'user_xyz' cannot create a client if client.userId != 'user_xyz'.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(clientId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /artists/{artistId} collection.
     * @path /databases/{database}/documents/artists/{artistId}
     * @allow (create) User with UID 'user_abc' can create an artist if artist.userId == 'user_abc'.
     * @allow (get, list) User with UID 'user_abc' can read an artist if artist.userId == 'user_abc'.
     * @allow (update, delete) User with UID 'user_abc' can update/delete an artist if artist.userId == 'user_abc'.
     * @deny (create) User with UID 'user_xyz' cannot create an artist if artist.userId != 'user_xyz'.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(artistId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /events/{eventId} collection.
     * @path /databases/{database}/documents/events/{eventId}
     * @allow (create) User with UID 'user_abc' can create an event if event.userId == 'user_abc'.
     * @allow (get, list) User with UID 'user_abc' can read an event if event.userId == 'user_abc'.
     * @allow (update, delete) User with UID 'user_abc' can update/delete an event if event.userId == 'user_abc'.
     * @deny (create) User with UID 'user_xyz' cannot create an event if event.userId != 'user_xyz'.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(eventId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /finances/{financeId} collection.
     * @path /databases/{database}/documents/finances/{financeId}
     * @allow (create) User with UID 'user_abc' can create a finance record if finance.userId == 'user_abc'.
     * @allow (get, list) User with UID 'user_abc' can read a finance record if finance.userId == 'user_abc'.
     * @allow (update, delete) User with UID 'user_abc' can update/delete a finance record if finance.userId == 'user_abc'.
     * @deny (create) User with UID 'user_xyz' cannot create a finance record if finance.userId != 'user_xyz'.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(financeId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /purchases/{purchaseId} collection.
     * @path /databases/{database}/documents/purchases/{purchaseId}
     * @allow (create) User with UID 'user_abc' can create a purchase if purchase.userId == 'user_abc'.
     * @allow (get, list) User with UID 'user_abc' can read a purchase if purchase.userId == 'user_abc'.
     * @allow (update, delete) User with UID 'user_abc' can update/delete a purchase if purchase.userId == 'user_abc'.
     * @deny (create) User with UID 'user_xyz' cannot create a purchase if purchase.userId != 'user_xyz'.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(purchaseId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }
  }

  // Helper Functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
  }
}