/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, identified by the `userId` field. Only the owning user can create, read, update,
 * or delete these documents.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for each entity type:
 * - /clients/{clientId}
 * - /artists/{artistId}
 * - /events/{eventId}
 * - /finances/{financeId}
 * - /purchases/{purchaseId}
 * Each document within these collections contains a `userId` field indicating the owner.
 *
 * Key Security Decisions:
 * - User data is strictly segregated. Users can only access data they own.
 * - No listing of other user's data is allowed.
 * - Data validation is minimal for prototyping, focusing on authorization and relational integrity.
 *
 * Denormalization for Authorization:
 * The `userId` field is present in every document to facilitate simple and efficient ownership checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the `clients` collection, ensuring only the owner can manage client data.
     * @path /clients/{clientId}
     * @allow (create) - User A creates a new client document with `userId: "A"`.
     * @allow (get, update, delete) - User A reads, updates, or deletes client document with `userId: "A"`.
     * @deny (create) - User A attempts to create a new client document with `userId: "B"`.
     * @deny (get, update, delete) - User B attempts to read, update, or delete client document with `userId: "A"`.
     * @principle Enforces document ownership for all operations on client data.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `artists` collection, ensuring only the owner can manage artist data.
     * @path /artists/{artistId}
     * @allow (create) - User A creates a new artist document with `userId: "A"`.
     * @allow (get, update, delete) - User A reads, updates, or deletes artist document with `userId: "A"`.
     * @deny (create) - User A attempts to create a new artist document with `userId: "B"`.
     * @deny (get, update, delete) - User B attempts to read, update, or delete artist document with `userId: "A"`.
     * @principle Enforces document ownership for all operations on artist data.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `events` collection, ensuring only the owner can manage event data.
     * @path /events/{eventId}
     * @allow (create) - User A creates a new event document with `userId: "A"`.
     * @allow (get, update, delete) - User A reads, updates, or deletes event document with `userId: "A"`.
     * @deny (create) - User A attempts to create a new event document with `userId: "B"`.
     * @deny (get, update, delete) - User B attempts to read, update, or delete event document with `userId: "A"`.
     * @principle Enforces document ownership for all operations on event data.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `finances` collection, ensuring only the owner can manage finance data.
     * @path /finances/{financeId}
     * @allow (create) - User A creates a new finance document with `userId: "A"`.
     * @allow (get, update, delete) - User A reads, updates, or deletes finance document with `userId: "A"`.
     * @deny (create) - User A attempts to create a new finance document with `userId: "B"`.
     * @deny (get, update, delete) - User B attempts to read, update, or delete finance document with `userId: "A"`.
     * @principle Enforces document ownership for all operations on finance data.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the `purchases` collection, ensuring only the owner can manage purchase data.
     * @path /purchases/{purchaseId}
     * @allow (create) - User A creates a new purchase document with `userId: "A"`.
     * @allow (get, update, delete) - User A reads, updates, or deletes purchase document with `userId: "A"`.
     * @deny (create) - User A attempts to create a new purchase document with `userId: "B"`.
     * @deny (get, update, delete) - User B attempts to read, update, or delete purchase document with `userId: "A"`.
     * @principle Enforces document ownership for all operations on purchase data.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}