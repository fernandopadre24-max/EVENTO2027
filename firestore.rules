/**
 * @fileOverview Firestore Security Rules for a musical group management application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, and only that user can create, read, update, or delete the document.
 *
 * Data Structure:
 * The Firestore database is organized with top-level collections for each entity type:
 * /clients/{clientId}
 * /artists/{artistId}
 * /events/{eventId}
 * /finances/{financeId}
 * /purchases/{purchaseId}
 *
 * Key Security Decisions:
 * - All data is private and requires authentication.
 * - User listing of documents is allowed within their own collections.
 * - No global admin roles are defined, defaulting to user-level ownership.
 *
 * Denormalization for Authorization:
 *  Each document includes a `userId` field, which is used to enforce ownership. This avoids the need for complex
 *  queries or joins to determine ownership, making the rules more efficient and secure. The rules validate that the
 * `userId` field matches the authenticated user's UID.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects all documents in the database.
     * @principle Requires authentication for all access.
     */
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages client information.
     * @path /clients/{clientId}
     * @allow (create) - Authenticated user can create a client if the userId matches their own.
     * @allow (read) - Authenticated user can read a client if the userId matches their own.
     * @allow (update) - Authenticated user can update a client if the userId matches their own.
     * @allow (delete) - Authenticated user can delete a client if the userId matches their own.
     * @deny (create) - Authenticated user cannot create a client for another user.
     * @deny (read) - Authenticated user cannot read a client owned by another user.
     * @deny (update) - Authenticated user cannot update a client owned by another user.
     * @deny (delete) - Authenticated user cannot delete a client owned by another user.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(clientId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages artist information.
     * @path /artists/{artistId}
     * @allow (create) - Authenticated user can create an artist if the userId matches their own.
     * @allow (read) - Authenticated user can read an artist if the userId matches their own.
     * @allow (update) - Authenticated user can update an artist if the userId matches their own.
     * @allow (delete) - Authenticated user can delete an artist if the userId matches their own.
     * @deny (create) - Authenticated user cannot create an artist for another user.
     * @deny (read) - Authenticated user cannot read an artist owned by another user.
     * @deny (update) - Authenticated user cannot update an artist owned by another user.
     * @deny (delete) - Authenticated user cannot delete an artist owned by another user.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(artistId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages event information.
     * @path /events/{eventId}
     * @allow (create) - Authenticated user can create an event if the userId matches their own.
     * @allow (read) - Authenticated user can read an event if the userId matches their own.
     * @allow (update) - Authenticated user can update an event if the userId matches their own.
     * @allow (delete) - Authenticated user can delete an event if the userId matches their own.
     * @deny (create) - Authenticated user cannot create an event for another user.
     * @deny (read) - Authenticated user cannot read an event owned by another user.
     * @deny (update) - Authenticated user cannot update an event owned by another user.
     * @deny (delete) - Authenticated user cannot delete an event owned by another user.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(eventId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages financial information.
     * @path /finances/{financeId}
     * @allow (create) - Authenticated user can create a finance record if the userId matches their own.
     * @allow (read) - Authenticated user can read a finance record if the userId matches their own.
     * @allow (update) - Authenticated user can update a finance record if the userId matches their own.
     * @allow (delete) - Authenticated user can delete a finance record if the userId matches their own.
     * @deny (create) - Authenticated user cannot create a finance record for another user.
     * @deny (read) - Authenticated user cannot read a finance record owned by another user.
     * @deny (update) - Authenticated user cannot update a finance record owned by another user.
     * @deny (delete) - Authenticated user cannot delete a finance record owned by another user.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(financeId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages purchase information.
     * @path /purchases/{purchaseId}
     * @allow (create) - Authenticated user can create a purchase record if the userId matches their own.
     * @allow (read) - Authenticated user can read a purchase record if the userId matches their own.
     * @allow (update) - Authenticated user can update a purchase record if the userId matches their own.
     * @allow (delete) - Authenticated user can delete a purchase record if the userId matches their own.
     * @deny (create) - Authenticated user cannot create a purchase record for another user.
     * @deny (read) - Authenticated user cannot read a purchase record owned by another user.
     * @deny (update) - Authenticated user cannot update a purchase record owned by another user.
     * @deny (delete) - Authenticated user cannot delete a purchase record owned by another user.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(purchaseId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the document.
     * @param {string} userId - The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the document and if the document exists.
     * @param {string} userId - The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}