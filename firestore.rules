/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each data entity (Client, Artist, Event, Finance, Purchase)
 * is owned by a specific user, and only that user has full CRUD access to their own data.
 *
 * Data Structure:
 * All data is stored in top-level collections: /clients/{clientId}, /artists/{artistId}, /events/{eventId},
 * /finances/{financeId}, and /purchases/{purchaseId}.
 *
 * Key Security Decisions:
 * - User listing is disallowed on all collections to prevent information disclosure.
 * - The rules explicitly deny any unauthorized access, ensuring a secure-by-default posture.
 * - Data validation is limited to ownership checks during creation and updates.
 *
 * Denormalization for Authorization:
 * - Each document includes a `userId` field, which is used to enforce ownership.
 *   This avoids the need for complex queries or additional reads to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure access to the 'artists' collection. Only the owner can create, read, update, or delete artists.
     * @path /databases/{database}/documents/artists/{artistId}
     * @allow (create) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an artist with artist.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read artist 'artistId' if it exists.
     * @allow (update) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update artist 'artistId' if they own it.
     * @allow (delete) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete artist 'artistId' if they own it.
     * @deny (create) - User ' অন্যuser' cannot create an artist with artist.userId != 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (get) - User ' অন্যuser' cannot read artist 'artistId' if it does not exist.
     * @deny (update) - User ' অন্যuser' cannot update artist 'artistId' they don't own.
     * @deny (delete) - User ' অন্যuser' cannot delete artist 'artistId' they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to the 'clients' collection. Only the owner can create, read, update, or delete clients.
     * @path /databases/{database}/documents/clients/{clientId}
     * @allow (create) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a client with client.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read client 'clientId' if it exists.
     * @allow (update) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update client 'clientId' if they own it.
     * @allow (delete) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete client 'clientId' if they own it.
     * @deny (create) - User ' অন্যuser' cannot create a client with client.userId != 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (get) - User ' অন্যuser' cannot read client 'clientId' if it does not exist.
     * @deny (update) - User ' অন্যuser' cannot update client 'clientId' they don't own.
     * @deny (delete) - User ' অন্যuser' cannot delete client 'clientId' they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to the 'events' collection. Only the owner can create, read, update, or delete events.
     * @path /databases/{database}/documents/events/{eventId}
     * @allow (create) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an event with event.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read event 'eventId' if it exists.
     * @allow (update) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update event 'eventId' if they own it.
     * @allow (delete) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete event 'eventId' if they own it.
     * @deny (create) - User ' অন্যuser' cannot create an event with event.userId != 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (get) - User ' অন্যuser' cannot read event 'eventId' if it does not exist.
     * @deny (update) - User ' অন্যuser' cannot update event 'eventId' they don't own.
     * @deny (delete) - User ' অন্যuser' cannot delete event 'eventId' they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to the 'finances' collection. Only the owner can create, read, update, or delete finances.
     * @path /databases/{database}/documents/finances/{financeId}
     * @allow (create) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a finance with finance.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read finance 'financeId' if it exists.
     * @allow (update) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update finance 'financeId' if they own it.
     * @allow (delete) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete finance 'financeId' if they own it.
     * @deny (create) - User ' অন্যuser' cannot create a finance with finance.userId != 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (get) - User ' অন্যuser' cannot read finance 'financeId' if it does not exist.
     * @deny (update) - User ' অন্যuser' cannot update finance 'financeId' they don't own.
     * @deny (delete) - User ' অন্যuser' cannot delete finance 'financeId' they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to the 'purchases' collection. Only the owner can create, read, update, or delete purchases.
     * @path /databases/{database}/documents/purchases/{purchaseId}
     * @allow (create) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a purchase with purchase.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read purchase 'purchaseId' if it exists.
     * @allow (update) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update purchase 'purchaseId' if they own it.
     * @allow (delete) - User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete purchase 'purchaseId' if they own it.
     * @deny (create) - User ' অন্যuser' cannot create a purchase with purchase.userId != 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (get) - User ' অন্যuser' cannot read purchase 'purchaseId' if it does not exist.
     * @deny (update) - User ' অন্যuser' cannot update purchase 'purchaseId' they don't own.
     * @deny (delete) - User ' অন্যuser' cannot delete purchase 'purchaseId' they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Check if user is owner and document exists
  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}