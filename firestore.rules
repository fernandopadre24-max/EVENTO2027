/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, and only that user can create, read, update, or delete the document.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections: /clients/{clientId}, /artists/{artistId},
 * /events/{eventId}, /finances/{financeId}, and /purchases/{purchaseId}. Each document within these collections
 * contains a 'userId' field indicating the owner.
 *
 * Key Security Decisions:
 * - User listing is disallowed for all collections, as this is generally a privacy risk.
 * - All write operations require the user to be authenticated and the 'userId' field in the document
 *   to match the authenticated user's UID.
 * - We denormalize the userId field onto every document to avoid needing to make expensive `get()` calls
 *   in the security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure client documents. Only the owner can create, read, update, or delete.
     * @path /clients/{clientId}
     * @allow (create) User with UID 'user_abc' can create a client document where client.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can get a client document where client.userId == 'user_abc'.
     * @allow (update) User with UID 'user_abc' can update a client document where client.userId == 'user_abc'.
     * @allow (delete) User with UID 'user_abc' can delete a client document where client.userId == 'user_abc'.
     * @deny (create) User with UID 'user_def' cannot create a client document where client.userId == 'user_abc'.
     * @deny (get) User with UID 'user_def' cannot get a client document where client.userId == 'user_abc'.
     * @deny (update) User with UID 'user_def' cannot update a client document where client.userId == 'user_abc'.
     * @deny (delete) User with UID 'user_def' cannot delete a client document where client.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure artist documents. Only the owner can create, read, update, or delete.
     * @path /artists/{artistId}
     * @allow (create) User with UID 'user_abc' can create an artist document where artist.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can get an artist document where artist.userId == 'user_abc'.
     * @allow (update) User with UID 'user_abc' can update an artist document where artist.userId == 'user_abc'.
     * @allow (delete) User with UID 'user_abc' can delete an artist document where artist.userId == 'user_abc'.
     * @deny (create) User with UID 'user_def' cannot create an artist document where artist.userId == 'user_abc'.
     * @deny (get) User with UID 'user_def' cannot get an artist document where artist.userId == 'user_abc'.
     * @deny (update) User with UID 'user_def' cannot update an artist document where artist.userId == 'user_abc'.
     * @deny (delete) User with UID 'user_def' cannot delete an artist document where artist.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure event documents. Only the owner can create, read, update, or delete.
     * @path /events/{eventId}
     * @allow (create) User with UID 'user_abc' can create an event document where event.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can get an event document where event.userId == 'user_abc'.
     * @allow (update) User with UID 'user_abc' can update an event document where event.userId == 'user_abc'.
     * @allow (delete) User with UID 'user_abc' can delete an event document where event.userId == 'user_abc'.
     * @deny (create) User with UID 'user_def' cannot create an event document where event.userId == 'user_abc'.
     * @deny (get) User with UID 'user_def' cannot get an event document where event.userId == 'user_abc'.
     * @deny (update) User with UID 'user_def' cannot update an event document where event.userId == 'user_abc'.
     * @deny (delete) User with UID 'user_def' cannot delete an event document where event.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure finance documents. Only the owner can create, read, update, or delete.
     * @path /finances/{financeId}
     * @allow (create) User with UID 'user_abc' can create a finance document where finance.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can get a finance document where finance.userId == 'user_abc'.
     * @allow (update) User with UID 'user_abc' can update a finance document where finance.userId == 'user_abc'.
     * @allow (delete) User with UID 'user_abc' can delete a finance document where finance.userId == 'user_abc'.
     * @deny (create) User with UID 'user_def' cannot create a finance document where finance.userId == 'user_abc'.
     * @deny (get) User with UID 'user_def' cannot get a finance document where finance.userId == 'user_abc'.
     * @deny (update) User with UID 'user_def' cannot update a finance document where finance.userId == 'user_abc'.
     * @deny (delete) User with UID 'user_def' cannot delete a finance document where finance.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure purchase documents. Only the owner can create, read, update, or delete.
     * @path /purchases/{purchaseId}
     * @allow (create) User with UID 'user_abc' can create a purchase document where purchase.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can get a purchase document where purchase.userId == 'user_abc'.
     * @allow (update) User with UID 'user_abc' can update a purchase document where purchase.userId == 'user_abc'.
     * @allow (delete) User with UID 'user_abc' can delete a purchase document where purchase.userId == 'user_abc'.
     * @deny (create) User with UID 'user_def' cannot create a purchase document where purchase.userId == 'user_abc'.
     * @deny (get) User with UID 'user_def' cannot get a purchase document where purchase.userId == 'user_abc'.
     * @deny (update) User with UID 'user_def' cannot update a purchase document where purchase.userId == 'user_abc'.
     * @deny (delete) User with UID 'user_def' cannot delete a purchase document where purchase.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if false;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}