/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model, ensuring that each user can only access data they own.
 *
 * Data Structure:
 * All data is stored in top-level collections: /clients/{clientId}, /artists/{artistId}, /events/{eventId}, /finances/{financeId}, and /purchases/{purchaseId}.
 * Each document in these collections contains a 'userId' field indicating the owner.
 *
 * Key Security Decisions:
 * - User ownership is enforced for all collections.
 * - Only authenticated users can access data.
 * - The 'userId' field in each document must match the authenticated user's UID.
 * - List operations are allowed only for the owner of the documents.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to client documents.
     * @path /clients/{clientId}
     * @allow (create) - User with UID 'user_abc' creates a new client document where client.userId == 'user_abc'.
     * @deny (create) - User with UID 'user_xyz' attempts to create a client document where client.userId == 'user_abc'.
     * @allow (get, list, update, delete) - User with UID 'user_abc' reads, lists, updates, or deletes a client document where client.userId == 'user_abc'.
     * @deny (get, list, update, delete) - User with UID 'user_xyz' attempts to read, list, update, or delete a client document where client.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      //Helper function to check if the user is the existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to artist documents.
     * @path /artists/{artistId}
     * @allow (create) - User with UID 'user_abc' creates a new artist document where artist.userId == 'user_abc'.
     * @deny (create) - User with UID 'user_xyz' attempts to create an artist document where artist.userId == 'user_abc'.
     * @allow (get, list, update, delete) - User with UID 'user_abc' reads, lists, updates, or deletes an artist document where artist.userId == 'user_abc'.
     * @deny (get, list, update, delete) - User with UID 'user_xyz' attempts to read, list, update, or delete an artist document where artist.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      //Helper function to check if the user is the existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to event documents.
     * @path /events/{eventId}
     * @allow (create) - User with UID 'user_abc' creates a new event document where event.userId == 'user_abc'.
     * @deny (create) - User with UID 'user_xyz' attempts to create an event document where event.userId == 'user_abc'.
     * @allow (get, list, update, delete) - User with UID 'user_abc' reads, lists, updates, or deletes an event document where event.userId == 'user_abc'.
     * @deny (get, list, update, delete) - User with UID 'user_xyz' attempts to read, list, update, or delete an event document where event.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      //Helper function to check if the user is the existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to finance documents.
     * @path /finances/{financeId}
     * @allow (create) - User with UID 'user_abc' creates a new finance document where finance.userId == 'user_abc'.
     * @deny (create) - User with UID 'user_xyz' attempts to create a finance document where finance.userId == 'user_abc'.
     * @allow (get, list, update, delete) - User with UID 'user_abc' reads, lists, updates, or deletes a finance document where finance.userId == 'user_abc'.
     * @deny (get, list, update, delete) - User with UID 'user_xyz' attempts to read, list, update, or delete a finance document where finance.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      //Helper function to check if the user is the existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to purchase documents.
     * @path /purchases/{purchaseId}
     * @allow (create) - User with UID 'user_abc' creates a new purchase document where purchase.userId == 'user_abc'.
     * @deny (create) - User with UID 'user_xyz' attempts to create a purchase document where purchase.userId == 'user_abc'.
     * @allow (get, list, update, delete) - User with UID 'user_abc' reads, lists, updates, or deletes a purchase document where purchase.userId == 'user_abc'.
     * @deny (get, list, update, delete) - User with UID 'user_xyz' attempts to read, list, update, or delete a purchase document where purchase.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      //Helper function to check if the user is the existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}