/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each data entity (Client, Artist, Event, Finance, Purchase) is owned by a specific user,
 * and only that user has full CRUD access to the data.
 *
 * Data Structure:
 * Data is organized into top-level collections: /clients/{clientId}, /artists/{artistId}, /events/{eventId}, /finances/{financeId}, and /purchases/{purchaseId}.
 * Each document within these collections contains a `userId` field indicating the owner.
 *
 * Key Security Decisions:
 * - No public listing of any collections. Listing is restricted to the owner only.
 * - The `userId` field within each document is the linchpin of the security model.
 *
 * Denormalization for Authorization:
 * The `userId` field is denormalized onto each document to enable simple and efficient ownership checks, avoiding the need for complex queries or `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /clients collection.
     * @path /clients/{clientId}
     * @allow (create, update, delete) User with matching UID in document can perform these operations.
     * @deny (create, update, delete) User without matching UID in document cannot perform these operations.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      function isValidClientCreate() {
          return request.resource.data.userId == request.auth.uid;
      }
      allow get: if true;
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isValidClientCreate();
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /artists collection.
     * @path /artists/{artistId}
     * @allow (create, update, delete) User with matching UID in document can perform these operations.
     * @deny (create, update, delete) User without matching UID in document cannot perform these operations.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      function isValidArtistCreate() {
          return request.resource.data.userId == request.auth.uid;
      }

      allow get: if true;
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isValidArtistCreate();
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /events collection.
     * @path /events/{eventId}
     * @allow (create, update, delete) User with matching UID in document can perform these operations.
     * @deny (create, update, delete) User without matching UID in document cannot perform these operations.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      function isValidEventCreate() {
          return request.resource.data.userId == request.auth.uid;
      }
      allow get: if true;
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isValidEventCreate();
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /finances collection.
     * @path /finances/{financeId}
     * @allow (create, update, delete) User with matching UID in document can perform these operations.
     * @deny (create, update, delete) User without matching UID in document cannot perform these operations.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      function isValidFinanceCreate() {
          return request.resource.data.userId == request.auth.uid;
      }
      allow get: if true;
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isValidFinanceCreate();
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (create, update, delete) User with matching UID in document can perform these operations.
     * @deny (create, update, delete) User without matching UID in document cannot perform these operations.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      function isValidPurchaseCreate() {
          return request.resource.data.userId == request.auth.uid;
      }

      allow get: if true;
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isValidPurchaseCreate();
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}