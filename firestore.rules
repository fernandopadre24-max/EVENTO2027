/**
 * @file Firestore Security Rules
 * @version 2
 *
 * @description
 * This ruleset enforces a public read, owner-only write model for the 'clients', 'artists', 'events', and 'finances' collections.
 *
 * Data Structure:
 * - /clients/{clientId}
 * - /artists/{artistId}
 * - /events/{eventId}
 * - /finances/{financeId}
 *
 * Key Security Decisions:
 * - Public read access is granted to all collections.
 * - Write access (create, update, delete) is restricted to authenticated users only.
 * - The user must "own" the document, as indicated by a matching `request.auth.uid` and a corresponding `ownerId` or similar field on the document.
 * - No schema validation is performed beyond the ownership check.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access and authenticated, owner-only write access to client documents.
     * @path /clients/{clientId}
     * @allow (get, list)
     * @allow (create) - Authenticated user can create a client document if the client ID matches their UID.
     * @allow (update, delete) - Authenticated user can update or delete a client document if they are the owner (client ID matches their UID) and the document exists.
     * @deny (create) - Unauthenticated user attempts to create a client document.
     * @deny (update, delete) - Unauthenticated user attempts to update or delete a client document.
     * @deny (update, delete) - Authenticated user attempts to update or delete a client document they do not own.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows public read access and authenticated, owner-only write access to artist documents.
     * @path /artists/{artistId}
     * @allow (get, list)
     * @allow (create) - Authenticated user can create an artist document if the artist ID matches their UID.
     * @allow (update, delete) - Authenticated user can update or delete an artist document if they are the owner (artist ID matches their UID) and the document exists.
     * @deny (create) - Unauthenticated user attempts to create an artist document.
     * @deny (update, delete) - Unauthenticated user attempts to update or delete an artist document.
     * @deny (update, delete) - Authenticated user attempts to update or delete an artist document they do not own.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows public read access and authenticated, owner-only write access to event documents.
     * @path /events/{eventId}
     * @allow (get, list)
     * @allow (create) - Authenticated user can create an event document if the event ID matches their UID.
     * @allow (update, delete) - Authenticated user can update or delete an event document if they are the owner (event ID matches their UID) and the document exists.
     * @deny (create) - Unauthenticated user attempts to create an event document.
     * @deny (update, delete) - Unauthenticated user attempts to update or delete an event document.
     * @deny (update, delete) - Authenticated user attempts to update or delete an event document they do not own.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows public read access and authenticated, owner-only write access to finance documents.
     * @path /finances/{financeId}
     * @allow (get, list)
     * @allow (create) - Authenticated user can create a finance document if the finance ID matches their UID.
     * @allow (update, delete) - Authenticated user can update or delete a finance document if they are the owner (finance ID matches their UID) and the document exists.
     * @deny (create) - Unauthenticated user attempts to create a finance document.
     * @deny (update, delete) - Unauthenticated user attempts to update or delete a finance document.
     * @deny (update, delete) - Authenticated user attempts to update or delete a finance document they do not own.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }
  }

  // Helper function to determine if a user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }
}