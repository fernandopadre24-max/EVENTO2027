/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each data entity (Client, Artist, Event, Finance, Purchase)
 * is owned by a specific user, identified by the `userId` field.  All read and write operations are restricted to the
 * owner of the data.
 *
 * Data Structure:
 * The Firestore database is organized into top-level collections for each entity type:
 * - /clients/{clientId}
 * - /artists/{artistId}
 * - /events/{eventId}
 * - /finances/{financeId}
 * - /purchases/{purchaseId}
 *
 * Key Security Decisions:
 * - User listing of all documents within a collection is allowed only to the owner.
 * - Schema validation is relaxed in this prototype phase, focusing on authorization.
 * - All write operations require a valid, authenticated user.
 *
 * Denormalization for Authorization:
 *  - All documents contain a `userId` field, which is used to enforce ownership. This avoids the need for complex
 *    queries or additional reads to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure access to client documents. Only the owner can read, create, update, or delete clients.
     * @path /clients/{clientId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a client if request.resource.data.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read client data if they own it.
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update/delete client data if they own it and the document exists.
     * @deny (create) User with ID 'anotherUserId' cannot create a client with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to artist documents. Only the owner can read, create, update, or delete artists.
     * @path /artists/{artistId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an artist if request.resource.data.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read artist data if they own it.
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update/delete artist data if they own it and the document exists.
     * @deny (create) User with ID 'anotherUserId' cannot create an artist with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to event documents. Only the owner can read, create, update, or delete events.
     * @path /events/{eventId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an event if request.resource.data.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read event data if they own it.
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update/delete event data if they own it and the document exists.
     * @deny (create) User with ID 'anotherUserId' cannot create an event with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to finance documents. Only the owner can read, create, update, or delete finance records.
     * @path /finances/{financeId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a finance record if request.resource.data.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read finance data if they own it.
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update/delete finance data if they own it and the document exists.
     * @deny (create) User with ID 'anotherUserId' cannot create a finance record with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure access to purchase documents. Only the owner can read, create, update, or delete purchases.
     * @path /purchases/{purchaseId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a purchase if request.resource.data.userId == 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can read purchase data if they own it.
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update/delete purchase data if they own it and the document exists.
     * @deny (create) User with ID 'anotherUserId' cannot create a purchase with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}