/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model, ensuring that each user can only access data they own.
 *
 * Data Structure:
 * All data is stored in top-level collections: /clients/{clientId}, /artists/{artistId}, /events/{eventId}, /finances/{financeId}, and /purchases/{purchaseId}.
 * Each document in these collections contains a 'userId' field indicating the owner.
 *
 * Key Security Decisions:
 * - User ownership is enforced for all collections.
 * - Only authenticated users can access data.
 * - The `list` operation is allowed for each collection, restricted to the owner.
 * - Data validation is relaxed to allow for rapid prototyping but enforces relational integrity by validating the `userId` on create and ensuring it is immutable on update.
 *
 * Denormalization for Authorization:
 * The 'userId' field is denormalized into each document to simplify ownership checks and avoid expensive `get()` operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to client data.
     * @path /clients/{clientId}
     * @allow (create) Authenticated user can create a client document where the userId matches their own.
     * @allow (get, list) Authenticated user can read client documents they own.
     * @allow (update, delete) Authenticated user can update or delete client documents they own.
     * @deny (create) Authenticated user cannot create a client document for another user.
     * @deny (update, delete) Authenticated user cannot update or delete client documents they don't own.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /clients/{clientId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to artist data.
     * @path /artists/{artistId}
     * @allow (create) Authenticated user can create an artist document where the userId matches their own.
     * @allow (get, list) Authenticated user can read artist documents they own.
     * @allow (update, delete) Authenticated user can update or delete artist documents they own.
     * @deny (create) Authenticated user cannot create an artist document for another user.
     * @deny (update, delete) Authenticated user cannot update or delete artist documents they don't own.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /artists/{artistId} {
       // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to event data.
     * @path /events/{eventId}
     * @allow (create) Authenticated user can create an event document where the userId matches their own.
     * @allow (get, list) Authenticated user can read event documents they own.
     * @allow (update, delete) Authenticated user can update or delete event documents they own.
     * @deny (create) Authenticated user cannot create an event document for another user.
     * @deny (update, delete) Authenticated user cannot update or delete event documents they don't own.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /events/{eventId} {
       // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to finance data.
     * @path /finances/{financeId}
     * @allow (create) Authenticated user can create a finance document where the userId matches their own.
     * @allow (get, list) Authenticated user can read finance documents they own.
     * @allow (update, delete) Authenticated user can update or delete finance documents they own.
     * @deny (create) Authenticated user cannot create a finance document for another user.
     * @deny (update, delete) Authenticated user cannot update or delete finance documents they don't own.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /finances/{financeId} {
       // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to purchase data.
     * @path /purchases/{purchaseId}
     * @allow (create) Authenticated user can create a purchase document where the userId matches their own.
     * @allow (get, list) Authenticated user can read purchase documents they own.
     * @allow (update, delete) Authenticated user can update or delete purchase documents they own.
     * @deny (create) Authenticated user cannot create a purchase document for another user.
     * @deny (update, delete) Authenticated user cannot update or delete purchase documents they don't own.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /purchases/{purchaseId} {
       // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if true;
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}