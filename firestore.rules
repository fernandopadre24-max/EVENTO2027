/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model, where each user can only access data they own.
 *
 * Data Structure:
 * All data is stored in top-level collections: /clients/{clientId}, /artists/{artistId}, /events/{eventId}, /finances/{financeId}, /purchases/{purchaseId}.
 * Each document contains a `userId` field indicating the owner.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own data.
 * - Listing of collections is restricted to the owner.
 * - Data validation is relaxed in this prototyping phase but critical relational fields like `userId` are validated for consistency.
 *
 * Denormalization for Authorization:
 * The `userId` field within each document is used for authorization, avoiding the need for additional reads or complex queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to client data. Only the owner can create, read, update, or delete clients.
     * @path /clients/{clientId}
     * @allow (create) User 'user_abc' can create a new client with client.userId == 'user_abc'.
     * @allow (get) User 'user_abc' can read client 'client_xyz' if client.userId == 'user_abc'.
     * @allow (update) User 'user_abc' can update client 'client_xyz' if client.userId == 'user_abc'.
     * @allow (delete) User 'user_abc' can delete client 'client_xyz' if client.userId == 'user_abc'.
     * @deny (create) User 'user_xyz' cannot create a client with client.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(request.resource.data.userId) && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to artist data. Only the owner can create, read, update, or delete artists.
     * @path /artists/{artistId}
     * @allow (create) User 'user_abc' can create a new artist with artist.userId == 'user_abc'.
     * @allow (get) User 'user_abc' can read artist 'artist_xyz' if artist.userId == 'user_abc'.
     * @allow (update) User 'user_abc' can update artist 'artist_xyz' if artist.userId == 'user_abc'.
     * @allow (delete) User 'user_abc' can delete artist 'artist_xyz' if artist.userId == 'user_abc'.
     * @deny (create) User 'user_xyz' cannot create an artist with artist.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(request.resource.data.userId) && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to event data. Only the owner can create, read, update, or delete events.
     * @path /events/{eventId}
     * @allow (create) User 'user_abc' can create a new event with event.userId == 'user_abc'.
     * @allow (get) User 'user_abc' can read event 'event_xyz' if event.userId == 'user_abc'.
     * @allow (update) User 'user_abc' can update event 'event_xyz' if event.userId == 'user_abc'.
     * @allow (delete) User 'user_abc' can delete event 'event_xyz' if event.userId == 'user_abc'.
     * @deny (create) User 'user_xyz' cannot create an event with event.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(request.resource.data.userId) && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to finance data. Only the owner can create, read, update, or delete finance records.
     * @path /finances/{financeId}
     * @allow (create) User 'user_abc' can create a new finance record with finance.userId == 'user_abc'.
     * @allow (get) User 'user_abc' can read finance record 'finance_xyz' if finance.userId == 'user_abc'.
     * @allow (update) User 'user_abc' can update finance record 'finance_xyz' if finance.userId == 'user_abc'.
     * @allow (delete) User 'user_abc' can delete finance record 'finance_xyz' if finance.userId == 'user_abc'.
     * @deny (create) User 'user_xyz' cannot create a finance record with finance.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(request.resource.data.userId) && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to purchase data. Only the owner can create, read, update, or delete purchase records.
     * @path /purchases/{purchaseId}
     * @allow (create) User 'user_abc' can create a new purchase record with purchase.userId == 'user_abc'.
     * @allow (get) User 'user_abc' can read purchase record 'purchase_xyz' if purchase.userId == 'user_abc'.
     * @allow (update) User 'user_abc' can update purchase record 'purchase_xyz' if purchase.userId == 'user_abc'.
     * @allow (delete) User 'user_abc' can delete purchase record 'purchase_xyz' if purchase.userId == 'user_abc'.
     * @deny (create) User 'user_xyz' cannot create a purchase record with purchase.userId == 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(request.resource.data.userId) && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return resource.data.userId == userId;
  }

  function isOwnerIdImmutable(userId) {
    return resource.data.userId == userId;
  }

  function isOwnerList() {
    return false;
  }
}