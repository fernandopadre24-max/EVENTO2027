/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, identified by the `userId` field.  Access is granted only to the owner of the document.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections: `/clients`, `/artists`, `/events`, `/finances`, and `/purchases`.
 * Each collection contains documents representing the respective entities. Each document has a 'userId' field
 * that indicates the owner.
 *
 * Key Security Decisions:
 * - Users can only access their own data. No cross-user access is allowed unless explicitly specified.
 * - Listing operations are restricted to the owner of the documents.
 *
 * Denormalization for Authorization:
 * - Each document includes a `userId` field. This denormalization simplifies the rules and avoids the need for complex queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the document.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /artists collection.
     * @path /artists/{artistId}
     * @allow (create) - Allow a user to create an artist document if the userId matches their auth.uid.
     * @allow (get, list) - Allow any authenticated user to read any artist document.
     * @allow (update, delete) - Allow the owner of the artist document to update or delete it.
     * @deny (create) - Deny creation if the userId does not match the authenticated user's uid.
     * @deny (update, delete) - Deny update or delete if the authenticated user is not the owner of the document.
     * @principle Enforces document ownership for writes. Allows public read access.
     */
    match /artists/{artistId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /clients collection.
     * @path /clients/{clientId}
     * @allow (create) - Allow a user to create a client document if the userId matches their auth.uid.
     * @allow (get, list) - Allow any authenticated user to read any client document.
     * @allow (update, delete) - Allow the owner of the client document to update or delete it.
     * @deny (create) - Deny creation if the userId does not match the authenticated user's uid.
     * @deny (update, delete) - Deny update or delete if the authenticated user is not the owner of the document.
     * @principle Enforces document ownership for writes. Allows public read access.
     */
    match /clients/{clientId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /events collection.
     * @path /events/{eventId}
     * @allow (create) - Allow a user to create an event document if the userId matches their auth.uid.
     * @allow (get, list) - Allow any authenticated user to read any event document.
     * @allow (update, delete) - Allow the owner of the event document to update or delete it.
     * @deny (create) - Deny creation if the userId does not match the authenticated user's uid.
     * @deny (update, delete) - Deny update or delete if the authenticated user is not the owner of the document.
     * @principle Enforces document ownership for writes. Allows public read access.
     */
    match /events/{eventId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /finances collection.
     * @path /finances/{financeId}
     * @allow (create) - Allow a user to create a finance document if the userId matches their auth.uid.
     * @allow (get, list) - Allow any authenticated user to read any finance document.
     * @allow (update, delete) - Allow the owner of the finance document to update or delete it.
     * @deny (create) - Deny creation if the userId does not match the authenticated user's uid.
     * @deny (update, delete) - Deny update or delete if the authenticated user is not the owner of the document.
     * @principle Enforces document ownership for writes. Allows public read access.
     */
    match /finances/{financeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (create) - Allow a user to create a purchase document if the userId matches their auth.uid.
     * @allow (get, list) - Allow any authenticated user to read any purchase document.
     * @allow (update, delete) - Allow the owner of the purchase document to update or delete it.
     * @deny (create) - Deny creation if the userId does not match the authenticated user's uid.
     * @deny (update, delete) - Deny update or delete if the authenticated user is not the owner of the document.
     * @principle Enforces document ownership for writes. Allows public read access.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}