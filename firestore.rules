/**
 * @fileOverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each data entity (Client, Artist, Event, Finance, Purchase) is owned by a specific user,
 * and only that user has full CRUD access to their own data.
 *
 * Data Structure:
 * All data is stored in top-level collections (e.g., /clients/{clientId}, /artists/{artistId}). Each document contains a `userId` field indicating ownership.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed for privacy.
 * - The default security posture is strict: if a relationship or permission is unclear, access is denied.
 *
 * Denormalization for Authorization:
 *  - Each document includes a `userId` field for direct owner validation, avoiding the need for additional `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure client documents. Only the owner can create, read, update, and delete.
     * @path /clients/{clientId}
     * @allow (create) User with UID 'user_abc' can create a client document if request.resource.data.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can read a client document they own.
     * @allow (update) User with UID 'user_abc' can update a client document they own.
     * @allow (delete) User with UID 'user_abc' can delete a client document they own.
     * @deny (create) User with UID 'user_xyz' cannot create a client document with userId 'user_abc'.
     * @deny (get) User with UID 'user_xyz' cannot read a client document owned by 'user_abc'.
     * @deny (update) User with UID 'user_xyz' cannot update a client document owned by 'user_abc'.
     * @deny (delete) User with UID 'user_xyz' cannot delete a client document owned by 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isNewOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure artist documents. Only the owner can create, read, update, and delete.
     * @path /artists/{artistId}
     * @allow (create) User with UID 'user_abc' can create an artist document if request.resource.data.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can read an artist document they own.
     * @allow (update) User with UID 'user_abc' can update an artist document they own.
     * @allow (delete) User with UID 'user_abc' can delete an artist document they own.
     * @deny (create) User with UID 'user_xyz' cannot create an artist document with userId 'user_abc'.
     * @deny (get) User with UID 'user_xyz' cannot read an artist document owned by 'user_abc'.
     * @deny (update) User with UID 'user_xyz' cannot update an artist document owned by 'user_abc'.
     * @deny (delete) User with UID 'user_xyz' cannot delete an artist document owned by 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isNewOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure event documents. Only the owner can create, read, update, and delete.
     * @path /events/{eventId}
     * @allow (create) User with UID 'user_abc' can create an event document if request.resource.data.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can read an event document they own.
     * @allow (update) User with UID 'user_abc' can update an event document they own.
     * @allow (delete) User with UID 'user_abc' can delete an event document they own.
     * @deny (create) User with UID 'user_xyz' cannot create an event document with userId 'user_abc'.
     * @deny (get) User with UID 'user_xyz' cannot read an event document owned by 'user_abc'.
     * @deny (update) User with UID 'user_xyz' cannot update an event document owned by 'user_abc'.
     * @deny (delete) User with UID 'user_xyz' cannot delete an event document owned by 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isNewOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure finance documents. Only the owner can create, read, update, and delete.
     * @path /finances/{financeId}
     * @allow (create) User with UID 'user_abc' can create a finance document if request.resource.data.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can read a finance document they own.
     * @allow (update) User with UID 'user_abc' can update a finance document they own.
     * @allow (delete) User with UID 'user_abc' can delete a finance document they own.
     * @deny (create) User with UID 'user_xyz' cannot create a finance document with userId 'user_abc'.
     * @deny (get) User with UID 'user_xyz' cannot read a finance document owned by 'user_abc'.
     * @deny (update) User with UID 'user_xyz' cannot update a finance document owned by 'user_abc'.
     * @deny (delete) User with UID 'user_xyz' cannot delete a finance document owned by 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isNewOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secure purchase documents. Only the owner can create, read, update, and delete.
     * @path /purchases/{purchaseId}
     * @allow (create) User with UID 'user_abc' can create a purchase document if request.resource.data.userId == 'user_abc'.
     * @allow (get) User with UID 'user_abc' can read a purchase document they own.
     * @allow (update) User with UID 'user_abc' can update a purchase document they own.
     * @allow (delete) User with UID 'user_abc' can delete a purchase document they own.
     * @deny (create) User with UID 'user_xyz' cannot create a purchase document with userId 'user_abc'.
     * @deny (get) User with UID 'user_xyz' cannot read a purchase document owned by 'user_abc'.
     * @deny (update) User with UID 'user_xyz' cannot update a purchase document owned by 'user_abc'.
     * @deny (delete) User with UID 'user_xyz' cannot delete a purchase document owned by 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && isNewOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isNewOwner(userId) {
        return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}