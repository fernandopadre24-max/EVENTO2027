/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, identified by the `userId` field.  Access is generally restricted to the owner.
 *
 * Data Structure:
 * - /clients/{clientId}: Stores information about clients, each owned by a user.
 * - /artists/{artistId}: Stores information about artists, each owned by a user.
 * - /events/{eventId}: Stores information about events, each owned by a user and associated with clients and artists.
 * - /finances/{financeId}: Stores financial records, each owned by a user and optionally associated with events and artists.
 * - /purchases/{purchaseId}: Stores purchase records, each owned by a user.
 *
 * Key Security Decisions:
 * - User Ownership: Most collections are secured using the "Ownership" access control pattern, where only the user who created the data can read, update, or delete it.
 * - No User Listing: There are no rules that allow listing all users.
 *
 * Denormalization for Authorization:
 * - Each document includes a `userId` field that stores the UID of the owning user. This denormalization is essential for efficient authorization checks without requiring additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @return {boolean} True if the request is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user IDs match, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     *              Also verifies that the document exists.
     * @param {string} userId The user ID to compare against the document's `userId` field.
     * @return {boolean} True if the user is the owner and the document exists.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Security rules for the /artists collection.
     * @path /artists/{artistId}
     * @allow (list) Authenticated user can list artists to fix reported error.
     * @allow (get) Authenticated user can get an artist if they are the owner.
     * @allow (create) Authenticated user can create an artist if the userId matches their own.
     * @allow (update) Authenticated user can update an artist if they are the owner and the document exists.
     * @allow (delete) Authenticated user can delete an artist if they are the owner and the document exists.
     * @deny (create) Non-authenticated users cannot create artists.
     * @deny (update) Non-authenticated users cannot update artists.
     * @deny (delete) Non-authenticated users cannot delete artists.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) ;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Security rules for the /clients collection.
     * @path /clients/{clientId}
     * @allow (get) Authenticated user can get a client if they are the owner.
     * @allow (list) Authenticated user can list clients if they are the owner.
     * @allow (create) Authenticated user can create a client if the userId matches their own.
     * @allow (update) Authenticated user can update a client if they are the owner and the document exists.
     * @allow (delete) Authenticated user can delete a client if they are the owner and the document exists.
     * @deny (create) Non-authenticated users cannot create clients.
     * @deny (update) Non-authenticated users cannot update clients.
     * @deny (delete) Non-authenticated users cannot delete clients.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Security rules for the /events collection.
     * @path /events/{eventId}
     * @allow (get) Authenticated user can get an event if they are the owner.
     * @allow (list) Authenticated user can list events if they are the owner.
     * @allow (create) Authenticated user can create an event if the userId matches their own.
     * @allow (update) Authenticated user can update an event if they are the owner and the document exists.
     * @allow (delete) Authenticated user can delete an event if they are the owner and the document exists.
     * @deny (create) Non-authenticated users cannot create events.
     * @deny (update) Non-authenticated users cannot update events.
     * @deny (delete) Non-authenticated users cannot delete events.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Security rules for the /finances collection.
     * @path /finances/{financeId}
     * @allow (get) Authenticated user can get a finance record if they are the owner.
     * @allow (list) Authenticated user can list finance records if they are the owner.
     * @allow (create) Authenticated user can create a finance record if the userId matches their own.
     * @allow (update) Authenticated user can update a finance record if they are the owner and the document exists.
     * @allow (delete) Authenticated user can delete a finance record if they are the owner and the document exists.
     * @deny (create) Non-authenticated users cannot create finance records.
     * @deny (update) Non-authenticated users cannot update finance records.
     * @deny (delete) Non-authenticated users cannot delete finance records.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Security rules for the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (get) Authenticated user can get a purchase record if they are the owner.
     * @allow (list) Authenticated user can list purchase records if they are the owner.
     * @allow (create) Authenticated user can create a purchase record if the userId matches their own.
     * @allow (update) Authenticated user can update a purchase record if they are the owner and the document exists.
     * @allow (delete) Authenticated user can delete a purchase record if they are the owner and the document exists.
     * @deny (create) Non-authenticated users cannot create purchase records.
     * @deny (update) Non-authenticated users cannot update purchase records.
     * @deny (delete) Non-authenticated users cannot delete purchase records.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}