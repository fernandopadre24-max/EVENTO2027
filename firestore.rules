/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model, where each document is owned by a specific user.
 *
 * Data Structure:
 * - All data is stored in top-level collections: /clients/{clientId}, /artists/{artistId}, /events/{eventId}, /finances/{financeId}, and /purchases/{purchaseId}.
 * - Each document within these collections has a 'userId' field indicating the owner.
 *
 * Key Security Decisions:
 * - Only authenticated users can access data.
 * - Users can only create, read, update, and delete documents they own (where document.userId == request.auth.uid).
 * - Listing of collections is restricted to the owner.
 *
 * Denormalization for Authorization:
 * - The 'userId' field is included in each document to enable simple ownership checks without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the 'clients' collection. Only the owner can create, read, update, and delete client documents.
     * @path /clients/{clientId}
     * @allow (create) User 'user_abc' can create a new client document if request.auth.uid == request.resource.data.userId.
     * @allow (get) User 'user_abc' can read client document where client.userId == request.auth.uid.
     * @allow (update) User 'user_abc' can update client document where client.userId == request.auth.uid.
     * @allow (delete) User 'user_abc' can delete client document where client.userId == request.auth.uid.
     * @deny (create) User 'user_xyz' cannot create a client document with userId 'user_abc'.
     * @deny (get) User 'user_xyz' cannot read client document where client.userId != request.auth.uid.
     * @deny (update) User 'user_xyz' cannot update client document where client.userId != request.auth.uid.
     * @deny (delete) User 'user_xyz' cannot delete client document where client.userId != request.auth.uid.
     * @principle Enforces document ownership for all operations on clients.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth != null && userId == request.auth.uid;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(clientId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'artists' collection. Only the owner can create, read, update, and delete artist documents.
     * @path /artists/{artistId}
     * @allow (create) User 'user_abc' can create a new artist document if request.auth.uid == request.resource.data.userId.
     * @allow (get) User 'user_abc' can read artist document where artist.userId == request.auth.uid.
     * @allow (update) User 'user_abc' can update artist document where artist.userId == request.auth.uid.
     * @allow (delete) User 'user_abc' can delete artist document where artist.userId == request.auth.uid.
     * @deny (create) User 'user_xyz' cannot create a artist document with userId 'user_abc'.
     * @deny (get) User 'user_xyz' cannot read artist document where artist.userId != request.auth.uid.
     * @deny (update) User 'user_xyz' cannot update artist document where artist.userId != request.auth.uid.
     * @deny (delete) User 'user_xyz' cannot delete artist document where artist.userId != request.auth.uid.
     * @principle Enforces document ownership for all operations on artists.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth != null && userId == request.auth.uid;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(artistId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'events' collection. Only the owner can create, read, update, and delete event documents.
     * @path /events/{eventId}
     * @allow (create) User 'user_abc' can create a new event document if request.auth.uid == request.resource.data.userId.
     * @allow (get) User 'user_abc' can read event document where event.userId == request.auth.uid.
     * @allow (update) User 'user_abc' can update event document where event.userId == request.auth.uid.
     * @allow (delete) User 'user_abc' can delete event document where event.userId == request.auth.uid.
     * @deny (create) User 'user_xyz' cannot create a event document with userId 'user_abc'.
     * @deny (get) User 'user_xyz' cannot read event document where event.userId != request.auth.uid.
     * @deny (update) User 'user_xyz' cannot update event document where event.userId != request.auth.uid.
     * @deny (delete) User 'user_xyz' cannot delete event document where event.userId != request.auth.uid.
     * @principle Enforces document ownership for all operations on events.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth != null && userId == request.auth.uid;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(eventId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'finances' collection. Only the owner can create, read, update, and delete finance documents.
     * @path /finances/{financeId}
     * @allow (create) User 'user_abc' can create a new finance document if request.auth.uid == request.resource.data.userId.
     * @allow (get) User 'user_abc' can read finance document where finance.userId == request.auth.uid.
     * @allow (update) User 'user_abc' can update finance document where finance.userId == request.auth.uid.
     * @allow (delete) User 'user_abc' can delete finance document where finance.userId == request.auth.uid.
     * @deny (create) User 'user_xyz' cannot create a finance document with userId 'user_abc'.
     * @deny (get) User 'user_xyz' cannot read finance document where finance.userId != request.auth.uid.
     * @deny (update) User 'user_xyz' cannot update finance document where finance.userId != request.auth.uid.
     * @deny (delete) User 'user_xyz' cannot delete finance document where finance.userId != request.auth.uid.
     * @principle Enforces document ownership for all operations on finances.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth != null && userId == request.auth.uid;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(financeId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'purchases' collection. Only the owner can create, read, update, and delete purchase documents.
     * @path /purchases/{purchaseId}
     * @allow (create) User 'user_abc' can create a new purchase document if request.auth.uid == request.resource.data.userId.
     * @allow (get) User 'user_abc' can read purchase document where purchase.userId == request.auth.uid.
     * @allow (update) User 'user_abc' can update purchase document where purchase.userId == request.auth.uid.
     * @allow (delete) User 'user_abc' can delete purchase document where purchase.userId == request.auth.uid.
     * @deny (create) User 'user_xyz' cannot create a purchase document with userId 'user_abc'.
     * @deny (get) User 'user_xyz' cannot read purchase document where purchase.userId != request.auth.uid.
     * @deny (update) User 'user_xyz' cannot update purchase document where purchase.userId != request.auth.uid.
     * @deny (delete) User 'user_xyz' cannot delete purchase document where purchase.userId != request.auth.uid.
     * @principle Enforces document ownership for all operations on purchases.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth != null && userId == request.auth.uid;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(purchaseId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}