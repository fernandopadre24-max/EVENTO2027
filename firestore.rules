/**
 * @description This ruleset enforces a strict authorization model where only authenticated users can access data.
 * All collections are readable by any authenticated user, but write access is forbidden.
 * @dataStructure The database consists of top-level collections for clients, artists, events, and finances.
 * @keySecurityDecisions
 *   - All collections are publicly readable by signed-in users, supporting open data access.
 *   - No write operations are allowed through the client; all data is considered read-only.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants read access to the 'clients' collection for any authenticated user.  Write access is denied.
     * @path /clients/{clientId}
     * @allow (get, list) An authenticated user can retrieve or list client documents.
     * @deny (create, update, delete) No user can create, update, or delete client documents.
     * @principle Allows any signed-in user to read client information, but prevents any modification.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to the 'artists' collection for any authenticated user.  Write access is denied.
     * @path /artists/{artistId}
     * @allow (get, list) An authenticated user can retrieve or list artist documents.
     * @deny (create, update, delete) No user can create, update, or delete artist documents.
     * @principle Allows any signed-in user to read artist information, but prevents any modification.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to the 'events' collection for any authenticated user.  Write access is denied.
     * @path /events/{eventId}
     * @allow (get, list) An authenticated user can retrieve or list event documents.
     * @deny (create, update, delete) No user can create, update, or delete event documents.
     * @principle Allows any signed-in user to read event information, but prevents any modification.
     */
    match /events/{eventId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to the 'finances' collection for any authenticated user.  Write access is denied.
     * @path /finances/{financeId}
     * @allow (get, list) An authenticated user can retrieve or list finance documents.
     * @deny (create, update, delete) No user can create, update, or delete finance documents.
     * @principle Allows any signed-in user to read finance information, but prevents any modification.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Helper function to determine if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
  }
}