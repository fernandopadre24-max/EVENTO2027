/**
 * @fileOverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset adopts a public read, owner-write model for the 'artists' collection, 
 * and enforces strict owner-only access for the 'clients', 'events', and 'finances' collections.
 *
 * Data Structure:
 * - /artists/{artistId}: Publicly readable collection of artist profiles.  Each artist document should have an `ownerId` field.
 * - /clients/{clientId}: Private collection of client contact information.
 * - /events/{eventId}: Private collection of event schedules.
 * - /finances/{financeId}: Private collection of financial records.
 *
 * Key Security Decisions:
 * - Artists collection is publicly listable.
 * - Clients, events, and finances are restricted to owner-only access.
 *
 * Denormalization for Authorization:
 * The 'artists' documents must contain an `ownerId` field to control write access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read artist profiles, but only the owner to create, update, or delete.
     * @path /artists/{artistId}
     * @allow (get, list) Allows any user to read the artist profile.
     * @allow (create) Allows a user to create an artist profile if the `ownerId` field matches their UID.
     * @allow (update, delete) Allows the owner of the artist profile to update or delete it.
     * @deny Any non-owner attempting to update or delete an artist profile.
     * @principle Enforces document ownership for writes while allowing public reads.
     */
    match /artists/{artistId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && request.resource.data.ownerId == resource.data.ownerId && request.auth.uid == resource.data.ownerId;
    }

    /**
     * @description Only allows the owner to read, create, update, or delete client information.
     * @path /clients/{clientId}
     * @allow (create) Allows a user to create their own client document if the client ID matches their UID.
     * @allow (get, list, update, delete) Allows the owner of the client document to read, list, update, and delete it.
     * @deny Any non-owner attempting to access or modify a client document.
     * @principle Restricts access to a user's own client data.
     */
    match /clients/{clientId} {
      allow get, list: if isSignedIn() && request.auth.uid == clientId;
      allow create: if isSignedIn() && request.auth.uid == clientId;
      allow update: if isSignedIn() && request.auth.uid == clientId;
      allow delete: if isSignedIn() && request.auth.uid == clientId;
    }

    /**
     * @description Only allows the owner to read, create, update, or delete event information.
     * @path /events/{eventId}
     * @allow (create) Allows a user to create their own event document.
     * @allow (get, list, update, delete) Allows the owner of the event document to read, update, and delete it.
     * @deny Any non-owner attempting to access or modify an event document.
     * @principle Restricts access to a user's own event data.
     */
    match /events/{eventId} {
      allow get, list: if isSignedIn() && request.auth.uid == eventId;
      allow create: if isSignedIn() && request.auth.uid == eventId;
      allow update: if isSignedIn() && request.auth.uid == eventId;
      allow delete: if isSignedIn() && request.auth.uid == eventId;
    }

    /**
     * @description Only allows the owner to read, create, update, or delete financial information.
     * @path /finances/{financeId}
     * @allow (create) Allows a user to create their own finance document.
     * @allow (get, list, update, delete) Allows the owner of the finance document to read, update, and delete it.
     * @deny Any non-owner attempting to access or modify a finance document.
     * @principle Restricts access to a user's own financial data.
     */
    match /finances/{financeId} {
      allow get, list: if isSignedIn() && request.auth.uid == financeId;
      allow create: if isSignedIn() && request.auth.uid == financeId;
      allow update: if isSignedIn() && request.auth.uid == financeId;
      allow delete: if isSignedIn() && request.auth.uid == financeId;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}