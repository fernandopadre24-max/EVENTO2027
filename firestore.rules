/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, identified by the `userId` field. Access is granted only to the owner.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections: /clients, /artists, /events, /finances, and /purchases.
 * Each document in these collections represents an entity and includes a `userId` field indicating ownership.
 *
 * Key Security Decisions:
 * - Users can only access documents they own.
 * - Listing of documents is restricted to the owner only. This prevents unauthorized data discovery.
 * - Data shape is not validated to allow for rapid prototyping, but the `userId` field is strictly enforced for authorization.
 *
 * Denormalization for Authorization:
 *  - The `userId` field is present in every document to avoid the need for complex queries or additional reads to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /artists collection.
     * @path /artists/{artistId}
     * @allow (list) User can list their own artists.
     * @allow (create) User can create a new artist with their userId.
     * @allow (get) User can get artist info if it is theirs.
     * @allow (update) User can update artist info if it is theirs.
     * @allow (delete) User can delete artist info if it is theirs.
     * @deny (list) User cannot list all artists from all users.
     * @deny (create) User cannot create an artist for another user.
     * @deny (update) User cannot update artist info if it is not theirs.
     * @deny (delete) User cannot delete artist info if it is not theirs.
     * @principle Enforces document ownership for reads and writes.
     */
    match /artists/{artistId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /clients collection.
     * @path /clients/{clientId}
     * @allow (list) User can list their own clients.
     * @allow (create) User can create a new client with their userId.
     * @allow (get) User can get client info if it is theirs.
     * @allow (update) User can update client info if it is theirs.
     * @allow (delete) User can delete client info if it is theirs.
     * @deny (list) User cannot list all clients from all users.
     * @deny (create) User cannot create a client for another user.
     * @deny (update) User cannot update client info if it is not theirs.
     * @deny (delete) User cannot delete client info if it is not theirs.
     * @principle Enforces document ownership for reads and writes.
     */
    match /clients/{clientId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(resource.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /events collection.
     * @path /events/{eventId}
     * @allow (list) User can list their own events.
     * @allow (create) User can create a new event with their userId.
     * @allow (get) User can get event info if it is theirs.
     * @allow (update) User can update event info if it is theirs.
     * @allow (delete) User can delete event info if it is theirs.
     * @deny (list) User cannot list all events from all users.
     * @deny (create) User cannot create an event for another user.
     * @deny (update) User cannot update event info if it is not theirs.
     * @deny (delete) User cannot delete event info if it is not theirs.
     * @principle Enforces document ownership for reads and writes.
     */
    match /events/{eventId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /finances collection.
     * @path /finances/{financeId}
     * @allow (list) User can list their own finances.
     * @allow (create) User can create a new finance document with their userId.
     * @allow (get) User can get finance info if it is theirs.
     * @allow (update) User can update finance info if it is theirs.
     * @allow (delete) User can delete finance info if it is theirs.
     * @deny (list) User cannot list all finances from all users.
     * @deny (create) User cannot create a finance document for another user.
     * @deny (update) User cannot update finance info if it is not theirs.
     * @deny (delete) User cannot delete finance info if it is not theirs.
     * @principle Enforces document ownership for reads and writes.
     */
    match /finances/{financeId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (list) User can list their own purchases.
     * @allow (create) User can create a new purchase document with their userId.
     * @allow (get) User can get purchase info if it is theirs.
     * @allow (update) User can update purchase info if it is theirs.
     * @allow (delete) User can delete purchase info if it is theirs.
     * @deny (list) User cannot list all purchases from all users.
     * @deny (create) User cannot create a purchase document for another user.
     * @deny (update) User cannot update purchase info if it is not theirs.
     * @deny (delete) User cannot delete purchase info if it is not theirs.
     * @principle Enforces document ownership for reads and writes.
     */
    match /purchases/{purchaseId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}