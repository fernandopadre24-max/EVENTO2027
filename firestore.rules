rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description This ruleset enforces a strict user-ownership model for all collections.
     * All data is organized in top-level collections without user-specific subcollections.
     * Each document is owned by a specific user, identified by a `userId` field within the document.
     * Only the owning user can read, create, update, or delete documents.
     * Listing of collections is restricted to the owner.
     *
     * Data Structure:
     * - /clients/{clientId}
     * - /artists/{artistId}
     * - /events/{eventId}
     * - /finances/{financeId}
     * - /purchases/{purchaseId}
     *
     * Key Security Decisions:
     * - No global admin roles are defined.
     * - User listing is disallowed on all collections.
     * - Missing 'userId' fields will result in DENY ALL for that collection.
     * - All documents contain a `userId` field that matches the authenticated user's UID.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Manages access to client documents.
     * @path /clients/{clientId}
     * @allow (create) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a client document if the userId field matches their UID.
     * @allow (update) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update a client document if they own it.
     * @allow (delete) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete a client document if they own it.
     * @deny (create) User 'anotherUser' cannot create a client document with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (update) User 'anotherUser' cannot update a client document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (delete) User 'anotherUser' cannot delete a client document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for writes and relational integrity for creates.
     */
    match /clients/{clientId} {
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to artist documents.
     * @path /artists/{artistId}
     * @allow (create) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an artist document if the userId field matches their UID.
     * @allow (update) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update an artist document if they own it.
     * @allow (delete) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete an artist document if they own it.
     * @deny (create) User 'anotherUser' cannot create an artist document with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (update) User 'anotherUser' cannot update an artist document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (delete) User 'anotherUser' cannot delete an artist document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for writes and relational integrity for creates.
     */
    match /artists/{artistId} {
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to event documents.
     * @path /events/{eventId}
     * @allow (create) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an event document if the userId field matches their UID.
     * @allow (update) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update an event document if they own it.
     * @allow (delete) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete an event document if they own it.
     * @deny (create) User 'anotherUser' cannot create an event document with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (update) User 'anotherUser' cannot update an event document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (delete) User 'anotherUser' cannot delete an event document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for writes and relational integrity for creates.
     */
    match /events/{eventId} {
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to finance documents.
     * @path /finances/{financeId}
     * @allow (create) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a finance document if the userId field matches their UID.
     * @allow (update) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update a finance document if they own it.
     * @allow (delete) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete a finance document if they own it.
     * @deny (create) User 'anotherUser' cannot create a finance document with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (update) User 'anotherUser' cannot update a finance document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (delete) User 'anotherUser' cannot delete a finance document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for writes and relational integrity for creates.
     */
    match /finances/{financeId} {
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Manages access to purchase documents.
     * @path /purchases/{purchaseId}
     * @allow (create) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a purchase document if the userId field matches their UID.
     * @allow (update) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update a purchase document if they own it.
     * @allow (delete) User 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can delete a purchase document if they own it.
     * @deny (create) User 'anotherUser' cannot create a purchase document with userId 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (update) User 'anotherUser' cannot update a purchase document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (delete) User 'anotherUser' cannot delete a purchase document owned by 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @principle Enforces document ownership for writes and relational integrity for creates.
     */
    match /purchases/{purchaseId} {
      allow get: if isExistingOwner(resource.data.userId);
      allow list: if isOwner(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }
  }
}