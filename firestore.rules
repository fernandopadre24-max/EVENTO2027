/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document is owned
 * by a specific user, identified by a `userId` field. Only the owner can
 * create, read, update, or delete their own documents.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for 'clients',
 * 'artists', 'events', 'finances', and 'purchases'. Each document within these
 * collections contains a `userId` field indicating the owner.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect privacy.
 * - The default security posture is strict: any access not explicitly allowed is denied.
 * - Data shape is not strictly validated in the prototyping phase, allowing for flexible schema changes.
 *
 * Denormalization for Authorization:
 * To simplify and optimize security rules, the `userId` is included directly in each document.
 * This avoids the need for complex `get()` calls to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the 'clients' collection.
     * @path /databases/{database}/documents/clients/{clientId}
     * @allow (create) User with UID 'user123' can create a client document with client.userId == 'user123'.
     * @allow (get, list) User with UID 'user123' can read a client document with client.userId == 'user123'.
     * @allow (update, delete) User with UID 'user123' can update/delete a client document with client.userId == 'user123'.
     * @deny (create) User with UID 'user123' cannot create a client document with client.userId != 'user123'.
     * @principle Enforces document ownership: only the owner can create, read, update, or delete.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'artists' collection.
     * @path /databases/{database}/documents/artists/{artistId}
     * @allow (create) User with UID 'user123' can create an artist document with artist.userId == 'user123'.
     * @allow (get, list) User with UID 'user123' can read an artist document with artist.userId == 'user123'.
     * @allow (update, delete) User with UID 'user123' can update/delete an artist document with artist.userId == 'user123'.
     * @deny (create) User with UID 'user123' cannot create an artist document with artist.userId != 'user123'.
     * @principle Enforces document ownership: only the owner can create, read, update, or delete.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'events' collection.
     * @path /databases/{database}/documents/events/{eventId}
     * @allow (create) User with UID 'user123' can create an event document with event.userId == 'user123'.
     * @allow (get, list) User with UID 'user123' can read an event document with event.userId == 'user123'.
     * @allow (update, delete) User with UID 'user123' can update/delete an event document with event.userId == 'user123'.
     * @deny (create) User with UID 'user123' cannot create an event document with event.userId != 'user123'.
     * @principle Enforces document ownership: only the owner can create, read, update, or delete.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'finances' collection.
     * @path /databases/{database}/documents/finances/{financeId}
     * @allow (create) User with UID 'user123' can create a finance document with finance.userId == 'user123'.
     * @allow (get, list) User with UID 'user123' can read a finance document with finance.userId == 'user123'.
     * @allow (update, delete) User with UID 'user123' can update/delete a finance document with finance.userId == 'user123'.
     * @deny (create) User with UID 'user123' cannot create a finance document with finance.userId != 'user123'.
     * @principle Enforces document ownership: only the owner can create, read, update, or delete.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the 'purchases' collection.
     * @path /databases/{database}/documents/purchases/{purchaseId}
     * @allow (create) User with UID 'user123' can create a purchase document with purchase.userId == 'user123'.
     * @allow (get, list) User with UID 'user123' can read a purchase document with purchase.userId == 'user123'.
     * @allow (update, delete) User with UID 'user123' can update/delete a purchase document with purchase.userId == 'user123'.
     * @deny (create) User with UID 'user123' cannot create a purchase document with purchase.userId != 'user123'.
     * @principle Enforces document ownership: only the owner can create, read, update, or delete.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(request.auth.uid);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}