/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, identified by the `userId` field.  Access is granted only to the owner of the document.
 *
 * Data Structure:
 * The Firestore database has a flat structure with top-level collections for clients, artists, events, finances, and purchases.
 * Each document in these collections contains a `userId` field indicating the owner.
 *
 * Key Security Decisions:
 * - **User Ownership:** All write operations (create, update, delete) are restricted to the owner of the document, as verified by the `userId` field and the `request.auth.uid`.
 * - **No User Listing:** Listing all users in the database is disallowed.
 * - **Read-Only Collections:** There are no read-only collections.
 *
 * Denormalization for Authorization:
 * Each document includes a `userId` field, denormalizing the user-ownership relationship. This avoids the need for costly `get()` operations to a separate `/users/{userId}` collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to client documents.
     * @path /clients/{clientId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a client with clientId 'testClientId' if the client's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (create) User with ID 'otherUserId' cannot create a client with clientId 'testClientId' if the client's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can get or list clients if they are the owner (tested via userId).
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update or delete a client with ID 'testClientId' if they are the owner (tested via userId) and the document exists.
     * @deny (update, delete) User with ID 'otherUserId' cannot update or delete a client with ID 'testClientId' even if they provide the correct data.
     * @principle Enforces document ownership for writes.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(clientId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows access to artist documents.
     * @path /artists/{artistId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an artist with artistId 'testArtistId' if the artist's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (create) User with ID 'otherUserId' cannot create an artist with artistId 'testArtistId' if the artist's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) Any signed-in user can get/list any artist.
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update or delete an artist with ID 'testArtistId' if they are the owner (tested via userId) and the document exists.
     * @deny (update, delete) User with ID 'otherUserId' cannot update or delete an artist with ID 'testArtistId' even if they provide the correct data.
     * @principle Enforces document ownership for writes.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows access to event documents.
     * @path /events/{eventId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create an event with eventId 'testEventId' if the event's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (create) User with ID 'otherUserId' cannot create an event with eventId 'testEventId' if the event's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can get or list events if they are the owner (tested via userId).
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update or delete an event with ID 'testEventId' if they are the owner (tested via userId) and the document exists.
     * @deny (update, delete) User with ID 'otherUserId' cannot update or delete an event with ID 'testEventId' even if they provide the correct data.
     * @principle Enforces document ownership for writes.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(eventId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows access to finance documents.
     * @path /finances/{financeId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a finance document with financeId 'testFinanceId' if the finance document's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (create) User with ID 'otherUserId' cannot create a finance document with financeId 'testFinanceId' if the finance document's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can get or list finance documents if they are the owner (tested via userId).
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update or delete a finance document with ID 'testFinanceId' if they are the owner (tested via userId) and the document exists.
     * @deny (update, delete) User with ID 'otherUserId' cannot update or delete a finance document with ID 'testFinanceId' even if they provide the correct data.
     * @principle Enforces document ownership for writes.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(financeId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows access to purchase documents.
     * @path /purchases/{purchaseId}
     * @allow (create) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can create a purchase document with purchaseId 'testPurchaseId' if the purchase document's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @deny (create) User with ID 'otherUserId' cannot create a purchase document with purchaseId 'testPurchaseId' if the purchase document's userId is 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2'.
     * @allow (get, list) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can get or list purchase documents if they are the owner (tested via userId).
     * @allow (update, delete) User with ID 'gETYfnFBVJVfsfUGGNaeSYy4Ikb2' can update or delete a purchase document with ID 'testPurchaseId' if they are the owner (tested via userId) and the document exists.
     * @deny (update, delete) User with ID 'otherUserId' cannot update or delete a purchase document with ID 'testPurchaseId' even if they provide the correct data.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(purchaseId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}