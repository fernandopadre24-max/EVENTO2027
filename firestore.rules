/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each data entity (Client, Artist, Event, Finance, Purchase) is owned by a specific user,
 * and only that user has full CRUD access to their own data.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for each entity type (clients, artists, events, finances, purchases).
 * Each document within these collections contains a `userId` field that identifies the owner.
 *
 * Key Security Decisions:
 * - User-only access: Listing all documents in a root collection such as `/finances` is disallowed.
 * - Ownership enforcement: Every write operation (create, update, delete) is strictly validated against the document's `userId` field and the authenticated user's UID.
 *
 * Denormalization for Authorization:
 * The `userId` field is present in every document to avoid having to perform complex queries or additional reads for authorization checks. This simplifies the rules and improves performance.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the /clients collection, allowing only the owner to read, create, update, and delete their own clients.
     * @path /databases/{database}/documents/clients/{clientId}
     * @allow (create) - User with UID 'user123' can create a new client document with client.userId == 'user123'.
     * @allow (get) - User with UID 'user123' can read client document with client.userId == 'user123'.
     * @allow (update) - User with UID 'user123' can update client document with client.userId == 'user123'.
     * @allow (delete) - User with UID 'user123' can delete client document with client.userId == 'user123'.
     * @deny (create) - User with UID 'user456' cannot create a client document with client.userId == 'user123'.
     * @deny (get) - User with UID 'user456' cannot read client document with client.userId == 'user123'.
     * @deny (update) - User with UID 'user456' cannot update client document with client.userId == 'user123'.
     * @deny (delete) - User with UID 'user456' cannot delete client document with client.userId == 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /artists collection, allowing only the owner to read, create, update, and delete their own artists.
     * @path /databases/{database}/documents/artists/{artistId}
     * @allow (create) - User with UID 'user123' can create a new artist document with artist.userId == 'user123'.
     * @allow (get) - User with UID 'user123' can read artist document with artist.userId == 'user123'.
     * @allow (update) - User with UID 'user123' can update artist document with artist.userId == 'user123'.
     * @allow (delete) - User with UID 'user123' can delete artist document with artist.userId == 'user123'.
     * @deny (create) - User with UID 'user456' cannot create an artist document with artist.userId == 'user123'.
     * @deny (get) - User with UID 'user456' cannot read artist document with artist.userId == 'user123'.
     * @deny (update) - User with UID 'user456' cannot update artist document with artist.userId == 'user123'.
     * @deny (delete) - User with UID 'user456' cannot delete artist document with artist.userId == 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /events collection, allowing only the owner to read, create, update, and delete their own events.
     * @path /databases/{database}/documents/events/{eventId}
     * @allow (create) - User with UID 'user123' can create a new event document with event.userId == 'user123'.
     * @allow (get) - User with UID 'user123' can read event document with event.userId == 'user123'.
     * @allow (update) - User with UID 'user123' can update event document with event.userId == 'user123'.
     * @allow (delete) - User with UID 'user123' can delete event document with event.userId == 'user123'.
     * @deny (create) - User with UID 'user456' cannot create an event document with event.userId == 'user123'.
     * @deny (get) - User with UID 'user456' cannot read event document with event.userId == 'user123'.
     * @deny (update) - User with UID 'user456' cannot update event document with event.userId == 'user123'.
     * @deny (delete) - User with UID 'user456' cannot delete event document with event.userId == 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /finances collection, allowing only the owner to read, create, update, and delete their own finances.
     * @path /databases/{database}/documents/finances/{financeId}
     * @allow (create) - User with UID 'user123' can create a new finance document with finance.userId == 'user123'.
     * @allow (get) - User with UID 'user123' can read finance document with finance.userId == 'user123'.
     * @allow (update) - User with UID 'user123' can update finance document with finance.userId == 'user123'.
     * @allow (delete) - User with UID 'user123' can delete finance document with finance.userId == 'user123'.
     * @deny (create) - User with UID 'user456' cannot create a finance document with finance.userId == 'user123'.
     * @deny (get) - User with UID 'user456' cannot read finance document with finance.userId == 'user123'.
     * @deny (update) - User with UID 'user456' cannot update finance document with finance.userId == 'user123'.
     * @deny (delete) - User with UID 'user456' cannot delete finance document with finance.userId == 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Secures the /purchases collection, allowing only the owner to read, create, update, and delete their own purchases.
     * @path /databases/{database}/documents/purchases/{purchaseId}
     * @allow (create) - User with UID 'user123' can create a new purchase document with purchase.userId == 'user123'.
     * @allow (get) - User with UID 'user123' can read purchase document with purchase.userId == 'user123'.
     * @allow (update) - User with UID 'user123' can update purchase document with purchase.userId == 'user123'.
     * @allow (delete) - User with UID 'user123' can delete purchase document with purchase.userId == 'user123'.
     * @deny (create) - User with UID 'user456' cannot create a purchase document with purchase.userId == 'user123'.
     * @deny (get) - User with UID 'user456' cannot read purchase document with purchase.userId == 'user123'.
     * @deny (update) - User with UID 'user456' cannot update purchase document with purchase.userId == 'user123'.
     * @deny (delete) - User with UID 'user456' cannot delete purchase document with purchase.userId == 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the document
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Helper function to determine if the user is the owner of the document and the document exists
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}