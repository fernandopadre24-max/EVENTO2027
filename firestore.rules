/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each document (client, artist, event, finance, purchase)
 * is owned by a specific user, and only that user can create, read, update, or delete the document.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for each entity:
 * /clients/{clientId}
 * /artists/{artistId}
 * /events/{eventId}
 * /finances/{financeId}
 * /purchases/{purchaseId}
 *
 * Each document contains a 'userId' field indicating the owner.
 *
 * Key Security Decisions:
 * - User listing is not allowed on any collection.
 * - Data schema is not strictly enforced, but the 'userId' field is validated on create and update
 *   to ensure proper ownership and immutability.
 *
 * Denormalization for Authorization:
 * To simplify and optimize rules, each document includes a 'userId' field that directly identifies the owner.
 * This avoids the need for complex queries or joins to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /clients/{clientId} collection.
     * @path /clients/{clientId}
     * @allow (create) User with auth UID 'user_abc' can create a client document if client.userId == 'user_abc'.
     * @deny (create) User with auth UID 'user_xyz' cannot create a client document if client.userId != 'user_xyz'.
     * @allow (get) User with auth UID 'user_abc' can read a client document if they own it.
     * @deny (get) User with auth UID 'user_xyz' cannot read a client document if they do not own it.
     * @allow (update) User with auth UID 'user_abc' can update a client document if they own it.
     * @deny (update) User with auth UID 'user_xyz' cannot update a client document if they do not own it.
     * @allow (delete) User with auth UID 'user_abc' can delete a client document if they own it.
     * @deny (delete) User with auth UID 'user_xyz' cannot delete a client document if they do not own it.
     * @principle Enforces document ownership for all operations.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /artists/{artistId} collection.
     * @path /artists/{artistId}
     * @allow (create) User with auth UID 'user_abc' can create an artist document if artist.userId == 'user_abc'.
     * @deny (create) User with auth UID 'user_xyz' cannot create an artist document if artist.userId != 'user_xyz'.
     * @allow (get) User with auth UID 'user_abc' can read an artist document if they own it.
     * @deny (get) User with auth UID 'user_xyz' cannot read an artist document if they do not own it.
     * @allow (update) User with auth UID 'user_abc' can update an artist document if they own it.
     * @deny (update) User with auth UID 'user_xyz' cannot update an artist document if they do not own it.
     * @allow (delete) User with auth UID 'user_abc' can delete an artist document if they own it.
     * @deny (delete) User with auth UID 'user_xyz' cannot delete an artist document if they do not own it.
     * @principle Enforces document ownership for all operations.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /events/{eventId} collection.
     * @path /events/{eventId}
     * @allow (create) User with auth UID 'user_abc' can create an event document if event.userId == 'user_abc'.
     * @deny (create) User with auth UID 'user_xyz' cannot create an event document if event.userId != 'user_xyz'.
     * @allow (get) User with auth UID 'user_abc' can read an event document if they own it.
     * @deny (get) User with auth UID 'user_xyz' cannot read an event document if they do not own it.
     * @allow (update) User with auth UID 'user_abc' can update an event document if they own it.
     * @deny (update) User with auth UID 'user_xyz' cannot update an event document if they do not own it.
     * @allow (delete) User with auth UID 'user_abc' can delete an event document if they own it.
     * @deny (delete) User with auth UID 'user_xyz' cannot delete an event document if they do not own it.
     * @principle Enforces document ownership for all operations.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /finances/{financeId} collection.
     * @path /finances/{financeId}
     * @allow (create) User with auth UID 'user_abc' can create a finance document if finance.userId == 'user_abc'.
     * @deny (create) User with auth UID 'user_xyz' cannot create a finance document if finance.userId != 'user_xyz'.
     * @allow (get) User with auth UID 'user_abc' can read a finance document if they own it.
     * @deny (get) User with auth UID 'user_xyz' cannot read a finance document if they do not own it.
     * @allow (update) User with auth UID 'user_abc' can update a finance document if they own it.
     * @deny (update) User with auth UID 'user_xyz' cannot update a finance document if they do not own it.
     * @allow (delete) User with auth UID 'user_abc' can delete a finance document if they own it.
     * @deny (delete) User with auth UID 'user_xyz' cannot delete a finance document if they do not own it.
     * @principle Enforces document ownership for all operations.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /purchases/{purchaseId} collection.
     * @path /purchases/{purchaseId}
     * @allow (create) User with auth UID 'user_abc' can create a purchase document if purchase.userId == 'user_abc'.
     * @deny (create) User with auth UID 'user_xyz' cannot create a purchase document if purchase.userId != 'user_xyz'.
     * @allow (get) User with auth UID 'user_abc' can read a purchase document if they own it.
     * @deny (get) User with auth UID 'user_xyz' cannot read a purchase document if they do not own it.
     * @allow (update) User with auth UID 'user_abc' can update a purchase document if they own it.
     * @deny (update) User with auth UID 'user_xyz' cannot update a purchase document if they do not own it.
     * @allow (delete) User with auth UID 'user_abc' can delete a purchase document if they own it.
     * @deny (delete) User with auth UID 'user_xyz' cannot delete a purchase document if they do not own it.
     * @principle Enforces document ownership for all operations.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the document
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

    // Helper function to determine if the user is the owner of the document and the document exists
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}