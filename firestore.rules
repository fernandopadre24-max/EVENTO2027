/**
 * @fileoverview Firestore Security Rules for the musical group app.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each data entity (Client, Artist, Event, Finance, Purchase) is owned by a specific user, and only that user can create, read, update, or delete their own data.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for each entity type: /clients/{clientId}, /artists/{artistId}, /events/{eventId}, /finances/{financeId}, and /purchases/{purchaseId}.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed for all collections to prevent unauthorized data enumeration.
 * - All write operations are validated against the authenticated user's ID to ensure ownership.
 * - Data validation is limited to enforcing ownership and relational integrity (e.g., creatorId), but does not validate the specific data types of each field.
 *
 * Denormalization for Authorization:
 * To ensure efficient authorization checks, each document includes a 'userId' field indicating the owner. This avoids the need for complex queries or additional reads to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /clients collection.
     * @path /clients/{clientId}
     * @allow (create) - User with ID 'user123' can create a client document if request.auth.uid == 'user123' and request.resource.data.userId == 'user123'.
     * @allow (get) - User with ID 'user123' can read a client document with userId == 'user123'.
     * @allow (update) - User with ID 'user123' can update a client document with userId == 'user123'.
     * @allow (delete) - User with ID 'user123' can delete a client document with userId == 'user123'.
     * @deny (create) - User with ID 'user456' cannot create a client document with userId == 'user123'.
     * @deny (get) - User with ID 'user456' cannot read a client document with userId == 'user123'.
     * @deny (update) - User with ID 'user456' cannot update a client document with userId == 'user123'.
     * @deny (delete) - User with ID 'user456' cannot delete a client document with userId == 'user123'.
     * @principle Enforces document ownership for all CRUD operations.
     */
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /artists collection.
     * @path /artists/{artistId}
     * @allow (create) - User with ID 'user123' can create an artist document if request.auth.uid == 'user123' and request.resource.data.userId == 'user123'.
     * @allow (get) - User with ID 'user123' can read an artist document with userId == 'user123'.
     * @allow (update) - User with ID 'user123' can update an artist document with userId == 'user123'.
     * @allow (delete) - User with ID 'user123' can delete an artist document with userId == 'user123'.
     * @deny (create) - User with ID 'user456' cannot create an artist document with userId == 'user123'.
     * @deny (get) - User with ID 'user456' cannot read an artist document with userId == 'user123'.
     * @deny (update) - User with ID 'user456' cannot update an artist document with userId == 'user123'.
     * @deny (delete) - User with ID 'user456' cannot delete an artist document with userId == 'user123'.
     * @principle Enforces document ownership for all CRUD operations.
     */
    match /artists/{artistId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /events collection.
     * @path /events/{eventId}
     * @allow (create) - User with ID 'user123' can create an event document if request.auth.uid == 'user123' and request.resource.data.userId == 'user123'.
     * @allow (get) - User with ID 'user123' can read an event document with userId == 'user123'.
     * @allow (update) - User with ID 'user123' can update an event document with userId == 'user123'.
     * @allow (delete) - User with ID 'user123' can delete an event document with userId == 'user123'.
     * @deny (create) - User with ID 'user456' cannot create an event document with userId == 'user123'.
     * @deny (get) - User with ID 'user456' cannot read an event document with userId == 'user123'.
     * @deny (update) - User with ID 'user456' cannot update an event document with userId == 'user123'.
     * @deny (delete) - User with ID 'user456' cannot delete an event document with userId == 'user123'.
     * @principle Enforces document ownership for all CRUD operations.
     */
    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /finances collection.
     * @path /finances/{financeId}
     * @allow (create) - User with ID 'user123' can create a finance document if request.auth.uid == 'user123' and request.resource.data.userId == 'user123'.
     * @allow (get) - User with ID 'user123' can read a finance document with userId == 'user123'.
     * @allow (update) - User with ID 'user123' can update a finance document with userId == 'user123'.
     * @allow (delete) - User with ID 'user123' can delete a finance document with userId == 'user123'.
     * @deny (create) - User with ID 'user456' cannot create a finance document with userId == 'user123'.
     * @deny (get) - User with ID 'user456' cannot read a finance document with userId == 'user123'.
     * @deny (update) - User with ID 'user456' cannot update a finance document with userId == 'user123'.
     * @deny (delete) - User with ID 'user456' cannot delete a finance document with userId == 'user123'.
     * @principle Enforces document ownership for all CRUD operations.
     */
    match /finances/{financeId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Controls access to the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (create) - User with ID 'user123' can create a purchase document if request.auth.uid == 'user123' and request.resource.data.userId == 'user123'.
     * @allow (get) - User with ID 'user123' can read a purchase document with userId == 'user123'.
     * @allow (update) - User with ID 'user123' can update a purchase document with userId == 'user123'.
     * @allow (delete) - User with ID 'user123' can delete a purchase document with userId == 'user123'.
     * @deny (create) - User with ID 'user456' cannot create a purchase document with userId == 'user123'.
     * @deny (get) - User with ID 'user456' cannot read a purchase document with userId == 'user123'.
     * @deny (update) - User with ID 'user456' cannot update a purchase document with userId == 'user123'.
     * @deny (delete) - User with ID 'user456' cannot delete a purchase document with userId == 'user123'.
     * @principle Enforces document ownership for all CRUD operations.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}