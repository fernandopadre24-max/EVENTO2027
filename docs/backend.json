
{
  "entities": {
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Represents a client of the musical group.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the client."
        },
        "email": {
          "type": "string",
          "description": "Contact email for the client."
        },
        "phone": {
          "type": "string",
          "description": "Contact phone for the client."
        },
        "responsavel": {
          "type": "string",
          "description": "Responsible person for the client."
        },
        "local": {
          "type": "string",
          "description": "Location/address of the client."
        },
        "instagram": {
          "type": "string",
          "description": "Instagram handle of the client."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this client."
        }
      },
      "required": [
        "name",
        "email",
        "phone",
        "responsavel",
        "local",
        "userId"
      ]
    },
    "Artist": {
      "title": "Artist",
      "type": "object",
      "description": "Represents an artist in the musical group.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the artist."
        },
        "genre": {
          "type": "string",
          "description": "Musical genre of the artist."
        },
        "performanceDetails": {
          "type": "string",
          "description": "Details about the artist's performance (e.g., genre, instruments)."
        },
        "instagram": {
          "type": "string",
          "description": "Instagram handle of the artist."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this artist."
        }
      },
      "required": [
        "name",
        "genre",
        "performanceDetails",
        "userId"
      ]
    },
    "Event": {
      "title": "Event",
      "type": "object",
      "description": "Represents a scheduled event for the musical group.",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "Reference to Client."
        },
        "artistIds": {
          "type": "array",
          "description": "References to Artists.",
          "items": {
            "type": "string"
          }
        },
        "date": {
          "type": "string",
          "description": "Date of the event.",
          "format": "date"
        },
        "time": {
          "type": "string",
          "description": "Time of the event."
        },
        "local": {
          "type": "string",
          "description": "Location of the event."
        },
        "payment": {
          "type": "number",
          "description": "Payment for the event."
        },
        "status": {
          "type": "string",
          "enum": [
            "Pendente",
            "Confirmado",
            "Concluído",
            "Cancelado"
          ]
        },
        "paymentStatus": {
          "type": "string",
          "enum": [
            "Não Pago",
            "Pago"
          ]
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this event."
        }
      },
      "required": [
        "clientId",
        "artistIds",
        "date",
        "time",
        "local",
        "payment",
        "status",
        "paymentStatus",
        "userId"
      ]
    },
    "Finance": {
      "title": "Finance",
      "type": "object",
      "description": "Represents financial information related to events or other income/expenses.",
      "properties": {
        "description": {
          "type": "string",
          "description": "Description of the financial transaction."
        },
        "amount": {
          "type": "number",
          "description": "Amount of the transaction (positive for income, negative for expense)."
        },
        "date": {
          "type": "string",
          "description": "Date of the financial transaction.",
          "format": "date"
        },
        "type": {
          "type": "string",
          "enum": [
            "Receita",
            "Despesa"
          ]
        },
        "eventId": {
          "type": "string",
          "description": "Reference to Event."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this financial record."
        }
      },
      "required": [
        "description",
        "amount",
        "date",
        "type",
        "userId"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": {
        "$ref": "#/entities/Client"
      },
      "description": "Stores client information."
    },
    "/artists/{artistId}": {
      "schema": {
        "$ref": "#/entities/Artist"
      },
      "description": "Stores artist information."
    },
    "/events/{eventId}": {
      "schema": {
        "$ref": "#/entities/Event"
      },
      "description": "Stores event information."
    },
    "/finances/{financeId}": {
      "schema": {
        "$ref": "#/entities/Finance"
      },
      "description": "Stores financial information."
    }
  }
}
